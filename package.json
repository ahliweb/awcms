{
  "name": "awcms",
  "version": "0.1.0",
  "private": true,
  "description": "AWCMS — Platform ERP & integrasi solusi bisnis, dibangun di atas fondasi awcms (Bun + Astro + PostgreSQL)",
  "license": "MIT",
  "author": "AhliWeb",
  "homepage": "https://github.com/ahliweb/awcms#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahliweb/awcms.git"
  },
  "bugs": {
    "url": "https://github.com/ahliweb/awcms/issues"
  },
  "keywords": [
    "erp",
    "modular-monolith",
    "bun",
    "astro",
    "postgresql",
    "multi-tenant",
    "rbac",
    "abac",
    "rls",
    "offline-first",
    "business-integration"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --bun astro dev",
    "build": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "start": "bun ./dist/server/entry.mjs",
    "db:migrate": "bun scripts/db-migrate.ts",
    "api:spec:check": "bun scripts/api-spec-check.ts",
    "modules:dag:check": "bun scripts/validate-module-graph.ts",
    "logging:lint:check": "bun scripts/logging-lint-check.ts",
    "config:validate": "bun scripts/validate-env.ts",
    "lint": "prettier --check \"**/*.md\" \"**/*.{json,yml,yaml}\" \"**/*.{ts,mjs,astro}\"",
    "format": "prettier --write \"**/*.md\" \"**/*.{json,yml,yaml}\" \"**/*.{ts,mjs,astro}\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "bun run lint && bun run api:spec:check && bun run modules:dag:check && bun run logging:lint:check && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/bun": "^1.3.14",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^7.0.2",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "astro": "^7.0.7"
  }
}

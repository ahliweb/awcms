        },
        "x-awcms-boundary": "internal",
        "x-awcms-scope": "tenant",
        "x-awcms-tenant-context": "optional",
        "x-awcms-r2": false,
        "x-awcms-soft-delete-aware": false,
        "x-awcms-permission": "tenant.notifications.send | tenant.notifications.manage"
      }
    },
    "/functions/v1/mailketing-webhook": {
      "post": {
        "operationId": "ingestMailketingWebhook",
        "tags": [
          "Messaging",
          "Operational"
        ],
        "summary": "Ingest Mailketing delivery webhook events",
        "description": "Internal callback used to record Mailketing events and update email status metadata.",
        "deprecated": false,
        "responses": {
          "200": {
            "description": "Webhook event ingested"
          },
          "400": {
            "description": "Error response",
            "content": {

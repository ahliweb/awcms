        "x-awcms-tenant-context": "optional",
        "x-awcms-r2": false,
        "x-awcms-soft-delete-aware": false,
        "x-awcms-permission": "platform.docs.read",
        "security": [
          {
            "secretHeaderAuth": []
          }
        ]
      }
    }
  }

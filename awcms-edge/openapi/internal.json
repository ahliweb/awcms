      "post": {
        "operationId": "queueSmandapbunPublicRebuildWebhook",
        "tags": [
          "Operational",
          "Public Portal"
        ],
        "summary": "Queue the SMANDAPBUN public rebuild callback",
        "description": "Server-to-server rebuild callback guarded by a shared secret header. This route is never exposed via public runtime docs.",
        "deprecated": false,

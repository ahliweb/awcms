{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "AWCMS Edge Internal API",
    "version": "1.0.0",
    "description": "Internal and maintenance awcms-edge routes for artifact generation only. This spec is not exposed at runtime."
  },
  "servers": [
    {
      "url": "https://edge.example.com",
      "description": "Current awcms-edge deployment origin"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Worker liveness and compatibility endpoints."
    },
    {
      "name": "Public Delivery",
      "description": "Public content and delivery surfaces safe for anonymous access."
    },
    {
      "name": "Human Verification",
      "description": "Turnstile and public anti-abuse verification flows."
    },
    {
      "name": "Applications",
      "description": "Public account application submission workflow."
    },
    {
      "name": "Identity",
      "description": "Authenticated identity and operator account management surfaces."
    },
    {
      "name": "Media",
      "description": "Authenticated media upload, access, and deletion flows."
    },
    {
      "name": "Public Portal",
      "description": "Tenant public rebuild orchestration and related delivery integrations."
    },
    {
      "name": "Content",
      "description": "Authenticated content processing routes."
    },
    {
      "name": "Extensions",
      "description": "Extension discovery, lifecycle, and health surfaces."
    },
    {
      "name": "Messaging",
      "description": "Messaging and email integration surfaces."
    },
    {
      "name": "Operational",
      "description": "Operational-only maintenance and webhook surfaces."
    }
  ],
  "components": {
    "securitySchemes": {
      "supabaseBearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase access token for authenticated operator requests."
      },
      "secretHeaderAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-awcms-rebuild-secret",
        "description": "Shared secret header for server-to-server rebuild callbacks."
      }
    }
  },
  "paths": {
    "/api/media/upload-proxy/{sessionId}": {
      "put": {
        "operationId": "putLocalDevUploadProxy",
        "tags": [
          "Operational"
        ],
        "summary": "Write upload bytes through the local-dev proxy",
        "description": "Local-dev upload proxy used only when direct presigned uploads are not available. Not part of the public runtime docs.",
        "deprecated": false,
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "description": "Upload session UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Upload bytes accepted"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "410": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "x-awcms-boundary": "internal",
        "x-awcms-scope": "tenant",
        "x-awcms-tenant-context": "none",
        "x-awcms-r2": true,
        "x-awcms-soft-delete-aware": false,
        "x-awcms-permission": "tenant.files.create | tenant.files.manage"
      }
    },
    "/api/media/import-local": {
      "post": {
        "operationId": "importLocalMediaMirror",
        "tags": [
          "Operational"
        ],
        "summary": "Import local media metadata and object bytes",
        "description": "Local-only maintenance route used to reconcile media objects into the local Worker storage emulator.",
        "deprecated": false,
        "responses": {
          "200": {
            "description": "Local media import completed"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "x-awcms-boundary": "internal",
        "x-awcms-scope": "platform",
        "x-awcms-tenant-context": "required",
        "x-awcms-r2": true,
        "x-awcms-soft-delete-aware": true,
        "x-awcms-permission": "platform.sync.manage",
        "security": [
          {
            "supabaseBearerAuth": []
          }
        ]
      }
    },
    "/api/media/cleanup-local-duplicates": {
      "post": {
        "operationId": "cleanupLocalMediaDuplicates",
        "tags": [
          "Operational"
        ],
        "summary": "Soft-delete duplicate local media objects",
        "description": "Local-only maintenance route used after media reconciliation to clean up duplicate rows and objects.",
        "deprecated": false,
        "responses": {
          "200": {
            "description": "Duplicate cleanup completed"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "x-awcms-boundary": "internal",
        "x-awcms-scope": "platform",
        "x-awcms-tenant-context": "required",
        "x-awcms-r2": true,
        "x-awcms-soft-delete-aware": true,
        "x-awcms-permission": "platform.sync.manage",
        "security": [
          {
            "supabaseBearerAuth": []
          }
        ]
      }
    },
    "/api/mailketing": {
      "post": {
        "operationId": "invokeMailketingApiAlias",
        "tags": [
          "Messaging",
          "Operational"
        ],
        "summary": "Invoke the Mailketing integration via API alias",
        "description": "Operational Mailketing integration alias for send, subscribe, credits, and lists actions. Kept out of public/admin runtime docs because runtime auth is not yet explicitly constrained by bearer middleware.",
        "deprecated": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "send",
                      "subscribe",
                      "credits",
                      "lists"
                    ]
                  }
                },
                "required": [
                  "action"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mailketing sync action completed"
          },
          "202": {
            "description": "Mailketing send action queued"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "x-awcms-boundary": "internal",
        "x-awcms-scope": "tenant",
        "x-awcms-tenant-context": "optional",
        "x-awcms-r2": false,
        "x-awcms-soft-delete-aware": false,
        "x-awcms-permission": "tenant.notifications.send | tenant.notifications.manage"
      }
    },
    "/functions/v1/mailketing": {
      "post": {
        "operationId": "invokeMailketingFunctionAlias",
        "tags": [
          "Messaging",
          "Operational"
        ],
        "summary": "Invoke the Mailketing integration via compatibility alias",
        "description": "Compatibility alias for the Mailketing integration with the same operational trust boundary as `/api/mailketing`.",
        "deprecated": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "send",
                      "subscribe",
                      "credits",
                      "lists"
                    ]
                  }
                },
                "required": [
                  "action"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mailketing sync action completed"
          },
          "202": {
            "description": "Mailketing send action queued"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {

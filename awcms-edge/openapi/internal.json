    "/api/admin/queue/replay": {
      "post": {
        "operationId": "replayDeadLetterQueueMessage",
        "tags": [
          "Operational"
        ],
        "summary": "Replay a dead-letter queue message",
        "description": "Platform-only operational route that re-enqueues a dead-letter message onto its live queue and records replay metadata.",
        "deprecated": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid"
                  }
                },
                "required": [
                  "id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dead-letter message replayed"
          },
          "400": {
            "description": "Error response",
            "content": {

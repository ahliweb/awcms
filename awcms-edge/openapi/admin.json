        "operationId": "manageUsersAdminActions",
        "tags": [
          "Identity"
        ],
        "summary": "Run authenticated user-management actions",
        "description": "Protected `manage-users` actions for invitations, creation, approval, updates, deletes, and account-request review. The public application submission flow is documented separately in the public spec.",
        "deprecated": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [

{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "AWCMS Edge Admin API",
    "version": "1.0.0",
    "description": "Authenticated awcms-edge admin routes only. OpenAPI is descriptive only and does not replace Supabase Auth, RLS, or ABAC."
  },
  "servers": [
    {
      "url": "https://edge.example.com",
      "description": "Current awcms-edge deployment origin"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Worker liveness and compatibility endpoints."
    },
    {
      "name": "Public Delivery",
      "description": "Public content and delivery surfaces safe for anonymous access."
    },
    {
      "name": "Human Verification",
      "description": "Turnstile and public anti-abuse verification flows."
    },
    {
      "name": "Applications",
      "description": "Public account application submission workflow."
    },
    {
      "name": "Identity",
      "description": "Authenticated identity and operator account management surfaces."
    },
    {
      "name": "Media",
      "description": "Authenticated media upload, access, and deletion flows."
    },
    {
      "name": "Public Portal",
      "description": "Tenant public rebuild orchestration and related delivery integrations."
    },
    {
      "name": "Content",
      "description": "Authenticated content processing routes."
    },
    {
      "name": "Extensions",
      "description": "Extension discovery, lifecycle, and health surfaces."
    },
    {
      "name": "Messaging",
      "description": "Messaging and email integration surfaces."
    },
    {
      "name": "Operational",
      "description": "Operational-only maintenance and webhook surfaces."
    }
  ],
  "components": {
    "securitySchemes": {
      "supabaseBearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase access token for authenticated operator requests."
      }
    }
  },
  "paths": {
    "/api/media/upload-session": {
      "post": {
        "operationId": "createMediaUploadSession",
        "tags": [
          "Media"
        ],
        "summary": "Create a media upload session",
        "description": "Creates a tenant-scoped upload session and returns the upload and finalize URLs. Supabase Auth, RLS, and ABAC remain authoritative.",
        "deprecated": false,
        "parameters": [
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "description": "Tenant UUID resolved by the caller. Supabase and Worker checks still enforce tenant isolation.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fileName": {
                    "type": "string"
                  },
                  "mimeType": {
                    "type": "string"
                  },
                  "sizeBytes": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "categoryId": {
                    "type": "string",
                    "format": "uuid",
                    "nullable": true
                  },
                  "folder": {
                    "type": "string",
                    "nullable": true
                  },
                  "accessControl": {
                    "type": "string",
                    "enum": [
                      "public",
                      "private"
                    ],
                    "nullable": true
                  },
                  "sessionBoundAccess": {
                    "type": "boolean",
                    "default": false
                  }
                },
                "required": [
                  "fileName",
                  "mimeType",
                  "sizeBytes"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload session created"
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "x-awcms-boundary": "admin",
        "x-awcms-scope": "tenant",
        "x-awcms-tenant-context": "required",
        "x-awcms-r2": true,
        "x-awcms-soft-delete-aware": false,
        "x-awcms-permission": "tenant.files.create | tenant.files.manage",
        "security": [
          {
            "supabaseBearerAuth": []
          }
        ]
      }
    },

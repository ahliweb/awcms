---
import Layout from "~/layouts/LandingLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { getLocale, t } from "~/utils/i18n";

const locale = getLocale(Astro.url);
const metadata = { title: t("landing.product.metadata.title", locale) };
---

<Layout metadata={metadata} pageType="landing_product">
  <PublicHero
    eyebrow={t("landing.product.hero.tagline", locale)}
    title={t("landing.product.hero.title", locale)}
    description={t("landing.product.hero.subtitle", locale)}
    image={{ src: "https://images.unsplash.com/photo-1473188588951-666fce8e7c68?ixlib=rb-4.0.3&auto=format&fit=crop&w=2174&q=80", alt: t("landing.product.hero.image_alt", locale) }}
    actions={[{ label: t("landing.hero.actions.cta", locale), href: "#" }, { label: t("landing.hero.actions.learn_more", locale), href: "#", variant: "secondary" }]}
    align="center"
  />
  <Section width="wide"><CtaBanner title={t("landing.coming_soon.title", locale)} description={t("landing.coming_soon.subtitle", locale)} action={{ label: t("landing.coming_soon.action", locale), href: "https://ahliweb.co.id" }} /></Section>
</Layout>

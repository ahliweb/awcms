---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import SplitSection from "~/components/public/SplitSection.astro";
import TestimonialGrid from "~/components/public/TestimonialGrid.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const metadata = {
  title: t("homes.personal.metadata.title", locale),
  description: t("homes.personal.hero.subtitle", locale),
};

const aboutItems = [
  { title: "Dribbble", description: "Design snapshots and experiments" },
  { title: "Behance", description: "Case studies and final projects" },
  { title: "Pinterest", description: "Moodboards and visual references" },
];

const experienceItems = [0, 1].map((index) => ({
  title: t(`homes.personal.resume.work_experience.items.${index}.title`, locale),
  description: t(`homes.personal.resume.work_experience.items.${index}.description`, locale),
  icon: "Work",
}));

const educationItems = [0, 1].map((index) => ({
  title: t(`homes.personal.resume.education.items.${index}.title`, locale),
  icon: "Edu",
}));

const skillItems = Array.from({ length: 9 }, (_, index) => ({
  title: t(`homes.personal.skills.items.${index}.title`, locale),
  description: t(`homes.personal.skills.items.${index}.description`, locale),
  icon: `S${index + 1}`,
}));

const project0 = [
  {
    title: t("homes.personal.portfolio.projects.0.description_title", locale),
    description: t("homes.personal.portfolio.projects.0.description", locale),
  },
  {
    title: t("homes.personal.portfolio.projects.0.role_title", locale),
    description: t("homes.personal.portfolio.projects.0.role", locale),
  },
];

const project1 = [
  {
    title: t("homes.personal.portfolio.projects.1.description_title", locale),
    description: t("homes.personal.portfolio.projects.1.description", locale),
  },
  {
    title: t("homes.personal.portfolio.projects.1.role_title", locale),
    description: t("homes.personal.portfolio.projects.1.role", locale),
  },
];

const project2 = [
  {
    title: t("homes.personal.portfolio.projects.2.description_title", locale),
    description: t("homes.personal.portfolio.projects.2.description", locale),
  },
  {
    title: t("homes.personal.portfolio.projects.2.role_title", locale),
    description: t("homes.personal.portfolio.projects.2.role", locale),
  },
];

const testimonials = Array.from({ length: 6 }, (_, index) => ({
  quote: t(`homes.personal.testimonials.items.${index}.testimonial`, locale),
  name: t(`homes.personal.testimonials.items.${index}.name`, locale),
  role: t(`homes.personal.testimonials.items.${index}.job`, locale),
}));
---

<Layout metadata={metadata} pageType="home_personal">
  <PublicHero
    eyebrow={t("homes.personal.hero.tagline", locale)}
    title={t("homes.personal.hero.title", locale)}
    description={t("homes.personal.hero.subtitle", locale)}
    actions={[{ label: t("homes.personal.cta.actions.hire_me", locale), href: `/${locale}/contact` }]}
    align="center"
  />

  <Section id="about" title={t("homes.personal.about.title", locale)} width="wide">
    <SplitSection
      title={t("homes.personal.about.title", locale)}
      description={`${t("homes.personal.about.p1", locale)} ${t("homes.personal.about.p2", locale)} ${t("homes.personal.about.p3", locale)}`}
      items={aboutItems}
      image={{
        src: "https://images.unsplash.com/photo-1491349174775-aaafddd81942?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80",
        alt: "Personal profile showcase",
      }}
    />
  </Section>

  <Section id="resume" title={t("homes.personal.resume.work_experience.title", locale)} width="wide" muted>
    <FeatureGrid items={experienceItems} columns={2} />
  </Section>

  <Section title={t("homes.personal.resume.education.title", locale)} width="wide">
    <FeatureGrid items={educationItems} columns={2} />
  </Section>

  <Section title={t("homes.personal.skills.title", locale)} description={t("homes.personal.skills.subtitle", locale)} width="wide" muted>
    <FeatureGrid items={skillItems} columns={3} />
  </Section>

  <Section id="porfolio" title={t("homes.personal.portfolio.title", locale)} description={t("homes.personal.portfolio.subtitle", locale)} width="wide">
    <div class="grid gap-10">
      <SplitSection
        title={t("homes.personal.portfolio.projects.0.title", locale)}
        items={project0}
        image={{ src: "https://images.unsplash.com/photo-1658248165252-71e116af1b34?ixlib=rb-4.0.3&auto=format&fit=crop&w=928&q=80", alt: "Portfolio project one" }}
        reverse
      />
      <SplitSection
        title={t("homes.personal.portfolio.projects.1.title", locale)}
        items={project1}
        image={{ src: "https://images.unsplash.com/photo-1619983081563-430f63602796?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80", alt: "Portfolio project two" }}
      />
      <SplitSection
        title={t("homes.personal.portfolio.projects.2.title", locale)}
        items={project2}
        image={{ src: "https://images.unsplash.com/photo-1558655146-d09347e92766?w=870&h=642&fit=crop", alt: "Portfolio project three" }}
        reverse
      />
    </div>
  </Section>

  <Section title={t("homes.personal.testimonials.title", locale)} description={t("homes.personal.testimonials.subtitle", locale)} width="wide" muted>
    <TestimonialGrid items={testimonials} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("homes.personal.cta.title", locale)}
      description={t("homes.personal.cta.subtitle", locale)}
      action={{ label: t("homes.personal.cta.actions.hire_me", locale), href: `/${locale}/contact` }}
    />
  </Section>
</Layout>

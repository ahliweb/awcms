---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import StatGrid from "~/components/public/StatGrid.astro";
import FaqList from "~/components/public/FaqList.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const metadata = {
  title: t("homes.startup.metadata.title", locale),
  description: t("homes.startup.hero.subtitle", locale),
};

const serviceItems = [0, 1, 2].map((index) => ({
  title: t(`homes.startup.services.items.${index}.title`, locale),
  description: t(`homes.startup.services.items.${index}.description`, locale),
  icon: `0${index + 1}`,
}));

const featureItems = [0, 1, 2, 3, 4, 5].map((index) => ({
  title: t(`homes.startup.features.items.${index}.title`, locale),
  description: t(`homes.startup.features.items.${index}.description`, locale),
  icon: `F${index + 1}`,
}));

const faqItems = [0, 1, 2, 3, 4, 5].map((index) => ({
  question: t(`homes.startup.faqs.items.${index}.title`, locale),
  answer: t(`homes.startup.faqs.items.${index}.description`, locale),
}));

const contactItems = ["phone", "email", "chat_sales", "chat_support"].map((key) => ({
  title: t(`homes.startup.contact.items.${key}.title`, locale),
  description: t(`homes.startup.contact.items.${key}.call_to_action`, locale),
  icon: key,
}));
---

<Layout metadata={metadata} pageType="home_startup">
  <PublicHero
    eyebrow={t("homes.startup.hero.tagline", locale)}
    title={t("homes.startup.hero.title", locale)}
    description={t("homes.startup.hero.subtitle", locale)}
    actions={[
      { label: t("homes.startup.hero.actions.get_templates", locale), href: "https://ahliweb.co.id" },
      { label: t("homes.startup.hero.actions.learn_more", locale), href: "#features", variant: "secondary" },
    ]}
    image={{
      src: "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80",
      alt: "Startup showcase",
    }}
  />

  <Section width="wide">
    <StatGrid
      items={[
        { label: t("homes.startup.stats.items.0.title", locale), value: "182K" },
        { label: t("homes.startup.stats.items.1.title", locale), value: "87" },
        { label: t("homes.startup.stats.items.2.title", locale), value: "4.8" },
        { label: t("homes.startup.stats.items.3.title", locale), value: "116K" },
      ]}
    />
  </Section>

  <Section title={t("homes.startup.services.title", locale)} description={t("homes.startup.services.subtitle", locale)} width="wide" muted>
    <FeatureGrid items={serviceItems} columns={3} />
  </Section>

  <Section id="features" title={t("homes.startup.features.title", locale)} description={t("homes.startup.features.subtitle", locale)} width="wide">
    <FeatureGrid items={featureItems} columns={3} />
  </Section>

  <Section title={t("homes.startup.faqs.title", locale)} width="narrow" muted>
    <FaqList items={faqItems} />
  </Section>

  <Section title={t("homes.startup.contact.title", locale)} description={t("homes.startup.contact.subtitle", locale)} width="wide">
    <FeatureGrid items={contactItems} columns={4} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("homes.startup.call_to_action.title", locale)}
      description={t("homes.startup.call_to_action.subtitle", locale)}
      action={{ label: t("homes.startup.call_to_action.actions.get_templates", locale), href: "https://ahliweb.co.id" }}
    />
  </Section>
</Layout>

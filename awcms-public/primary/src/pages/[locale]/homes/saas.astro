---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import SplitSection from "~/components/public/SplitSection.astro";
import FaqList from "~/components/public/FaqList.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const metadata = {
  title: t("homes.saas.metadata.title", locale),
  description: t("homes.saas.hero.subtitle", locale),
};

const featureItems = [0, 1, 2, 3, 4, 5].map((index) => ({
  title: t(`homes.saas.features.items.${index}.title`, locale),
  description: t(`homes.saas.features.items.${index}.description`, locale),
  icon: `F${index + 1}`,
}));

const startupItems = [
  {
    title: t("homes.saas.use_cases.startup.description_title", locale),
    description: t("homes.saas.use_cases.startup.description", locale),
  },
  {
    title: t("homes.saas.use_cases.startup.benefits_title", locale),
    description: t("homes.saas.use_cases.startup.benefits", locale),
  },
];

const saasItems = [
  {
    title: t("homes.saas.use_cases.saas.description_title", locale),
    description: t("homes.saas.use_cases.saas.description", locale),
  },
  {
    title: t("homes.saas.use_cases.saas.benefits_title", locale),
    description: t("homes.saas.use_cases.saas.benefits", locale),
  },
];

const faqItems = [0, 1, 2, 3].map((index) => ({
  question: t(`homes.saas.faqs.items.${index}.title`, locale),
  answer: t(`homes.saas.faqs.items.${index}.description`, locale),
}));

const pricingItems = [0, 1, 2].map((index) => ({
  title: t(`homes.saas.pricing.plans.${index}.title`, locale),
  description: t(`homes.saas.pricing.plans.${index}.subtitle`, locale),
  icon: index === 1 ? "Popular" : `P${index + 1}`,
}));
---

<Layout metadata={metadata} pageType="home_saas">
  <PublicHero
    eyebrow={t("homes.saas.hero.tagline", locale)}
    title={t("homes.saas.hero.title", locale)}
    description={t("homes.saas.hero.subtitle", locale)}
    actions={[
      { label: t("homes.saas.hero.actions.get_started", locale), href: "https://ahliweb.co.id" },
      { label: t("homes.saas.hero.actions.learn_more", locale), href: "#features", variant: "secondary" },
    ]}
    image={{
      src: "https://images.unsplash.com/photo-1580481072645-022f9a6dbf27?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80",
      alt: "SaaS showcase",
    }}
  />

  <Section id="features" title={t("homes.saas.features.title", locale)} description={t("homes.saas.features.subtitle", locale)} width="wide">
    <FeatureGrid items={featureItems} columns={3} />
  </Section>

  <Section width="wide" muted>
    <SplitSection
      title={t("homes.saas.use_cases.startup.content_title", locale)}
      items={startupItems}
      image={{
        src: "https://images.unsplash.com/photo-1620558138198-cfb9b4f3c294?ixlib=rb-4.0.3&auto=format&fit=crop&w=1671&q=80",
        alt: "Startup use case",
      }}
      reverse
    />
  </Section>

  <Section width="wide">
    <SplitSection
      title={t("homes.saas.use_cases.saas.content_title", locale)}
      items={saasItems}
      image={{
        src: "https://images.unsplash.com/photo-1531973486364-5fa64260d75b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1658&q=80",
        alt: "SaaS use case",
      }}
    />
  </Section>

  <Section title={t("homes.saas.pricing.title", locale)} width="wide" muted>
    <FeatureGrid items={pricingItems} columns={3} />
  </Section>

  <Section title={t("homes.saas.faqs.title", locale)} width="narrow">
    <FaqList items={faqItems} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("homes.saas.contact.title", locale)}
      description={t("homes.saas.contact.subtitle", locale)}
      action={{ label: t("homes.saas.contact.call_to_action", locale), href: `/${locale}/contact` }}
    />
  </Section>
</Layout>

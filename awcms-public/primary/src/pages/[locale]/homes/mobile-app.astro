---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import SplitSection from "~/components/public/SplitSection.astro";
import StatGrid from "~/components/public/StatGrid.astro";
import TestimonialGrid from "~/components/public/TestimonialGrid.astro";
import FaqList from "~/components/public/FaqList.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const appStoreDownloadLink = "https://ahliweb.co.id";
const googlePlayDownloadLink = "https://ahliweb.co.id";

const metadata = {
  title: t("homes.mobile_app.metadata.title", locale),
  description: `${t("homes.mobile_app.hero.subtitle", locale)} ${t("homes.mobile_app.hero.subtitle_continued", locale)}`,
};

const featureItems = [0, 1, 2, 3].map((index) => ({
  title: t(`homes.mobile_app.features.items.${index}.title`, locale),
  description: t(`homes.mobile_app.features.items.${index}.description`, locale),
  icon: `0${index + 1}`,
}));

const mainFeatureItems = [0, 1, 2, 3].map((index) => ({
  title: t(`homes.mobile_app.main_features.items.${index}.title`, locale),
  description: t(`homes.mobile_app.main_features.items.${index}.description`, locale),
}));

const otherFeatureItems = [0, 1, 2, 3].map((index) => ({
  title: t(`homes.mobile_app.other_features.items.${index}.title`, locale),
  description: t(`homes.mobile_app.other_features.items.${index}.description`, locale),
}));

const testimonials = [0, 1, 2].map((index) => ({
  quote: t(`homes.mobile_app.testimonials.items.${index}.testimonial`, locale),
  name: t(`homes.mobile_app.testimonials.items.${index}.name`, locale),
  role: t(`homes.mobile_app.testimonials.items.${index}.job`, locale),
}));

const faqs = [0, 1, 2, 3, 4].map((index) => ({
  question: t(`homes.mobile_app.faqs.items.${index}.title`, locale),
  answer: t(`homes.mobile_app.faqs.items.${index}.description`, locale),
}));
---

<Layout metadata={metadata} pageType="home_mobile_app">
  <PublicHero
    eyebrow={t("homes.mobile_app.hero.tagline", locale)}
    title={t("homes.mobile_app.hero.title_html", locale)}
    description={`${t("homes.mobile_app.hero.subtitle", locale)} ${t("homes.mobile_app.hero.subtitle_continued", locale)}`}
    image={{
      src: "https://images.unsplash.com/photo-1535303311164-664fc9ec6532?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80",
      alt: "Mobile app showcase",
    }}
    actions={[
      { label: "App Store", href: appStoreDownloadLink },
      { label: "Google Play", href: googlePlayDownloadLink, variant: "secondary" },
    ]}
  />

  <Section
    id="features"
    eyebrow={t("homes.mobile_app.features.tagline", locale)}
    title={t("homes.mobile_app.features.title", locale)}
    description={t("homes.mobile_app.features.subtitle", locale)}
    width="wide"
  >
    <FeatureGrid items={featureItems} columns={2} />
  </Section>

  <Section width="wide" muted>
    <SplitSection
      title={t("homes.mobile_app.main_features.title", locale)}
      items={mainFeatureItems}
      image={{
        src: "https://images.unsplash.com/photo-1576153192621-7a3be10b356e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1674&q=80",
        alt: "Main mobile features",
      }}
      reverse
    />
  </Section>

  <Section width="wide">
    <SplitSection
      title={t("homes.mobile_app.other_features.title", locale)}
      items={otherFeatureItems}
      image={{
        src: "https://images.unsplash.com/photo-1453738773917-9c3eff1db985?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80",
        alt: "Additional mobile features",
      }}
    />
  </Section>

  <Section title={t("homes.mobile_app.stats.title", locale)} width="wide" muted>
    <StatGrid
      items={[
        { value: "20K", label: "Downloads" },
        { value: "18.5K", label: "Users" },
        { value: "4.7", label: "Rating" },
      ]}
    />
  </Section>

  <Section title={t("homes.mobile_app.testimonials.title", locale)} width="wide">
    <TestimonialGrid items={testimonials} />
  </Section>

  <Section title={t("homes.mobile_app.faqs.title", locale)} width="narrow" muted>
    <FaqList items={faqs} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("homes.mobile_app.cta.title", locale)}
      description={t("homes.mobile_app.cta.subtitle", locale)}
      action={{ label: "App Store", href: appStoreDownloadLink }}
    />
  </Section>
</Layout>

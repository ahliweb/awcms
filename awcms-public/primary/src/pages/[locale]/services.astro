---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import SplitSection from "~/components/public/SplitSection.astro";
import TestimonialGrid from "~/components/public/TestimonialGrid.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const metadata = {
  title: t("services_page.hero.tagline", locale),
  description: t("services_page.hero.subtitle", locale),
};

const serviceItems = [
  "educational",
  "interior",
  "photography",
  "ecommerce",
  "blog",
  "business",
  "branding",
  "medical",
  "fashion",
].map((key) => ({
  title: t(`services_page.features.items.${key}.title`, locale),
  description: t(`services_page.features.items.${key}.description`, locale),
  icon: key,
}));

const mainFeatureItems = [0, 1, 2, 3].map((index) => ({
  title: t(`services_page.main_features.items.${index}.title`, locale),
  description: t(`services_page.main_features.items.${index}.desc`, locale),
}));

const benefitItems = ["time", "appearance", "cost", "download"].map((key) => ({
  title: t(`services_page.benefits.items.${key}`, locale),
  description: t(`services_page.benefits.items.${key}_desc`, locale),
}));

const testimonials = ["emily", "sarah", "mark"].map((key) => ({
  quote: t(`services_page.testimonials.items.${key}.testimonial`, locale),
  name: t(`services_page.testimonials.items.${key}.name`, locale),
  role: t(`services_page.testimonials.items.${key}.job`, locale),
}));
---

<Layout metadata={metadata} pageType="services_page">
  <PublicHero
    eyebrow={t("services_page.hero.tagline", locale)}
    title={t("services_page.hero.title", locale)}
    description={t("services_page.hero.subtitle", locale)}
    actions={[{ label: t("services_page.hero.cta", locale), href: `/${locale}` }]}
    image={{
      src: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80",
      alt: "Services showcase",
    }}
  />

  <Section title={t("services_page.features.title", locale)} description={t("services_page.features.subtitle", locale)} width="wide">
    <FeatureGrid items={serviceItems} columns={3} />
  </Section>

  <Section width="wide" muted>
    <SplitSection
      title={t("services_page.main_features.title", locale)}
      items={mainFeatureItems}
      image={{
        src: "https://images.unsplash.com/photo-1525909002-1b05e0c869d8?ixlib=rb-4.0.3&auto=format&fit=crop&w=870&q=80",
        alt: "Main service features",
      }}
      reverse
    />
  </Section>

  <Section width="wide">
    <SplitSection
      title={t("services_page.benefits.title", locale)}
      items={benefitItems}
      image={{
        src: "https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80",
        alt: "Service benefits",
      }}
    />
  </Section>

  <Section title={t("services_page.testimonials.title", locale)} width="wide" muted>
    <TestimonialGrid items={testimonials} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("services_page.cta.title", locale)}
      description={t("services_page.cta.subtitle", locale)}
      action={{ label: t("services_page.cta.action", locale), href: `/${locale}` }}
    />
  </Section>
</Layout>

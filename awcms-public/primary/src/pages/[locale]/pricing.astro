---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import FaqList from "~/components/public/FaqList.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const metadata = {
  title: t("pricing_page.hero.tagline", locale),
  description: t("pricing_page.hero.subtitle", locale),
};

const plans = ["basic", "standard", "premium"].map((key) => ({
  title: t(`pricing_page.prices.${key}.title`, locale),
  description: [0, 1, 2, 3, 4]
    .map((index) => t(`pricing_page.prices.${key}.items.${index}`, locale))
    .filter((value) => value && !value.includes(`items.`))
    .join(" | "),
  icon: key === "standard" ? "Popular" : key,
}));

const benefits = ["tiered", "transparent", "secure", "access", "upgrade", "support"].map((key) => ({
  title: t(`pricing_page.features.items.${key}.title`, locale),
  description: t(`pricing_page.features.items.${key}.desc`, locale),
  icon: key,
}));

const faqs = ["support", "trial", "switch", "payment", "fees"].map((key) => ({
  question: t(`pricing_page.faqs.items.${key}.title`, locale),
  answer: t(`pricing_page.faqs.items.${key}.desc`, locale),
}));
---

<Layout metadata={metadata} pageType="pricing_page">
  <PublicHero
    eyebrow={t("pricing_page.hero.tagline", locale)}
    title={t("pricing_page.hero.title", locale)}
    description={t("pricing_page.hero.subtitle", locale)}
    align="center"
  />

  <Section title={t("pricing_page.prices.title", locale)} description={t("pricing_page.prices.subtitle", locale)} width="wide">
    <FeatureGrid items={plans} columns={3} />
  </Section>

  <Section title={t("pricing_page.features.title", locale)} description={t("pricing_page.features.subtitle", locale)} width="wide" muted>
    <FeatureGrid items={benefits} columns={3} />
  </Section>

  <Section title={t("pricing_page.faqs.title", locale)} description={t("pricing_page.faqs.subtitle", locale)} width="narrow">
    <FaqList items={faqs} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("pricing_page.cta.title", locale)}
      description={t("pricing_page.cta.subtitle", locale)}
      action={{ label: t("pricing_page.cta.action", locale), href: `/${locale}` }}
    />
  </Section>
</Layout>

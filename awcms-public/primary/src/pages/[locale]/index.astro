---
/**
 * Localized Home Page
 * Path: /[locale]
 */
import HomePageContent from "~/components/public/HomePageContent.astro";
import { supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  const dedicatedLocalizedHomeRoutes = new Set<Locale>(["en", "id"]);

  return supportedLocales
    .filter((locale) => !dedicatedLocalizedHomeRoutes.has(locale))
    .map((locale) => ({
      params: { locale },
    }));
}

const { locale } = Astro.params as { locale: Locale };
---

<HomePageContent locale={locale} />

---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import ContactUs from "~/components/widgets/Contact.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";
import { getPublicTenantId } from "~/lib/publicTenant";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const tenantId = getPublicTenantId();

const metadata = {
  title: t("contact_page.hero.tagline", locale),
  description: t("contact_page.form.subtitle", locale),
};

const supportItems = [
  {
    title: t("contact_page.features.items.general.title", locale),
    description: t("contact_page.features.items.general.desc", locale),
    icon: "General",
  },
  {
    title: t("contact_page.features.items.sales.title", locale),
    description: t("contact_page.features.items.sales.desc", locale),
    icon: "Sales",
  },
  {
    title: t("contact_page.features.items.technical.title", locale),
    description: t("contact_page.features.items.technical.desc", locale),
    icon: "Tech",
  },
  {
    title: t("contact_page.features.items.phone.title", locale),
    description: t("contact_page.features.items.phone.description", locale),
    icon: "Phone",
  },
  {
    title: t("contact_page.features.items.email.title", locale),
    description: t("contact_page.features.items.email.description", locale),
    icon: "Email",
  },
  {
    title: t("contact_page.features.items.location.title", locale),
    description: t("contact_page.features.items.location.description", locale),
    icon: "Visit",
  },
];
---

<Layout metadata={metadata} pageType="contact_page">
  <PublicHero
    eyebrow={t("contact_page.hero.tagline", locale)}
    title={t("contact_page.hero.title", locale)}
    description={t("contact_page.form.subtitle", locale)}
    align="center"
  />

  <Section width="wide">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:items-start">
      <div class="rounded-[2rem] border border-slate-200/70 bg-white p-6 shadow-sm shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-950 dark:shadow-none sm:p-8">
        <ContactUs
          id="form"
          tenantId={tenantId ?? undefined}
          title={t("contact_page.form.title", locale)}
          subtitle={t("contact_page.form.subtitle", locale)}
          inputs={[
            { type: "text", name: "name", label: t("contact_page.form.inputs.name", locale) },
            { type: "email", name: "email", label: t("contact_page.form.inputs.email", locale) },
          ]}
          textarea={{ label: t("contact_page.form.inputs.message", locale) }}
          disclaimer={{ label: t("contact_page.form.disclaimer", locale) }}
          description={t("contact_page.form.description", locale)}
        />
      </div>

      <div class="rounded-[2rem] border border-slate-200/70 bg-slate-950 p-8 text-white dark:border-slate-800 dark:bg-slate-900">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary/80">
          {t("contact_page.features.title", locale)}
        </p>
        <h2 class="mt-4 text-2xl font-bold tracking-tight">
          {t("contact_page.form.title", locale)}
        </h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          {t("contact_page.form.description", locale)}
        </p>
      </div>
    </div>
  </Section>

  <Section
    title={t("contact_page.features.title", locale)}
    description={t("contact_page.form.description", locale)}
    width="wide"
    muted
  >
    <FeatureGrid items={supportItems} columns={3} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("contact_page.hero.title", locale)}
      description={t("contact_page.form.subtitle", locale)}
      action={{ label: t("common.search", locale) || "Explore", href: `/${locale}` }}
    />
  </Section>
</Layout>

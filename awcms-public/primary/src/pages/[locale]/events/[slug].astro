---
import Layout from "~/layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";
import { supportedLocales, type Locale } from "~/utils/i18n";
import { getPublicTenantId } from "~/lib/publicTenant";
import { getPublicEventBySlug, getPublicEvents } from "~/lib/events";

export const prerender = true;

export async function getStaticPaths() {
  const tenantId = getPublicTenantId();
  if (!tenantId) {
    return [];
  }

  const events = await getPublicEvents(tenantId, { limit: 48 });
  return supportedLocales.flatMap((locale) =>
    events.map((eventItem) => ({
      params: { locale, slug: eventItem.slug },
      props: { eventItem },
    })),
  );
}

const { locale } = Astro.params as { locale: Locale };
const tenantId = getPublicTenantId();
const { eventItem: staticEvent } = Astro.props as { eventItem?: Awaited<ReturnType<typeof getPublicEventBySlug>> };
const slug = Astro.params.slug || "";
const eventItem = staticEvent || (tenantId ? await getPublicEventBySlug(tenantId, slug) : null);

if (!eventItem) {
  return Astro.redirect(`/${locale}/events`);
}

const metadata = {
  title: eventItem.title,
  description: eventItem.summary || (locale === "id" ? "Detail agenda" : "Event details"),
};
---

<Layout metadata={metadata}>
  <section class="py-12 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-4xl px-6 sm:px-8">
      <a href={`/${locale}/events`} class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
        <Icon name="tabler:arrow-left" class="h-4 w-4" />
        {locale === "id" ? "Kembali ke agenda" : "Back to events"}
      </a>

      <article class="rounded-3xl border border-border bg-card/90 p-8 shadow-sm">
        <div class="mb-6 flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
            <Icon name="tabler:calendar-event" class="h-3.5 w-3.5" />
            {new Date(eventItem.start_at).toLocaleDateString(locale, {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
          <span class="text-xs uppercase tracking-wide text-muted-foreground">{eventItem.status}</span>
        </div>

        <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">{eventItem.title}</h1>

        {eventItem.summary ? (
          <p class="mt-6 text-lg leading-8 text-muted-foreground">{eventItem.summary}</p>
        ) : null}

        <dl class="mt-10 grid gap-6 rounded-2xl border border-border/70 bg-background/70 p-6 sm:grid-cols-2">
          <div>
            <dt class="mb-2 text-sm font-medium text-foreground">{locale === "id" ? "Mulai" : "Starts"}</dt>
            <dd class="text-sm text-muted-foreground">{new Date(eventItem.start_at).toLocaleString(locale)}</dd>
          </div>
          {eventItem.end_at ? (
            <div>
              <dt class="mb-2 text-sm font-medium text-foreground">{locale === "id" ? "Selesai" : "Ends"}</dt>
              <dd class="text-sm text-muted-foreground">{new Date(eventItem.end_at).toLocaleString(locale)}</dd>
            </div>
          ) : null}
          {eventItem.location ? (
            <div class="sm:col-span-2">
              <dt class="mb-2 text-sm font-medium text-foreground">{locale === "id" ? "Lokasi" : "Location"}</dt>
              <dd class="text-sm text-muted-foreground">{eventItem.location}</dd>
            </div>
          ) : null}
        </dl>
      </article>
    </div>
  </section>
</Layout>

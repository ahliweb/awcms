---
import Layout from "~/layouts/PageLayout.astro";
import PublicHero from "~/components/public/Hero.astro";
import Section from "~/components/public/Section.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import SplitSection from "~/components/public/SplitSection.astro";
import StatGrid from "~/components/public/StatGrid.astro";
import CtaBanner from "~/components/public/CtaBanner.astro";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const metadata = {
  title: t("about.title", locale),
  description: t("about.hero.subtitle", locale),
};

const templateItems = ["educational", "interior", "photography"].map((key) => ({
  title: t(`about.features_templates.items.${key}.title`, locale),
  description: t(`about.features_templates.items.${key}.desc`, locale),
  icon: key,
}));

const categoryItems = ["ecommerce", "blog", "business", "branding", "medical", "fashion"].map((key) => ({
  title: t(`about.features_categories.items.${key}.title`, locale),
  description: t(`about.features_categories.items.${key}.desc`, locale),
  icon: key,
}));

const values = ["customer_centric", "improvement", "ethical"].map((key) => ({
  title: t(`about.values.items.${key}.title`, locale),
  description: t(`about.values.items.${key}.desc`, locale),
}));

const achievements = ["global", "feedback", "awards"].map((key) => ({
  title: t(`about.achievements.items.${key}.title`, locale),
  description: t(`about.achievements.items.${key}.desc`, locale),
  icon: key,
}));

const locations = ["us", "spain", "australia", "brazil"].map((key) => ({
  title: t(`about.locations.items.${key}.title`, locale),
  description: t(`about.locations.items.${key}.description`, locale),
  icon: key.toUpperCase(),
}));

const support = ["chat", "call"].map((key) => ({
  title: t(`about.support.items.${key}.title`, locale),
  description: t(`about.support.items.${key}.desc`, locale),
  icon: key,
}));
---

<Layout metadata={metadata} pageType="about_page">
  <PublicHero
    eyebrow={t("about.hero.tagline", locale)}
    title={t("about.hero.title_html", locale)}
    description={t("about.hero.subtitle", locale)}
    image={{
      src: "https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80",
      alt: "About team",
    }}
  />

  <Section width="wide">
    <StatGrid
      items={[
        { label: t("about.stats.offices", locale), value: "4" },
        { label: t("about.stats.employees", locale), value: "248" },
        { label: t("about.stats.templates", locale), value: "12" },
        { label: t("about.stats.awards", locale), value: "24" },
      ]}
    />
  </Section>

  <Section title={t("about.features_templates.title", locale)} description={t("about.features_templates.subtitle", locale)} width="wide">
    <FeatureGrid items={templateItems} columns={3} />
  </Section>

  <Section width="wide" muted>
    <SplitSection
      title={t("about.values.title", locale)}
      description={t("about.values.subtitle", locale)}
      items={values}
      image={{
        src: "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80",
        alt: "About values",
      }}
      reverse
    />
  </Section>

  <Section title={t("about.achievements.title", locale)} description={t("about.achievements.subtitle", locale)} width="wide">
    <FeatureGrid items={achievements} columns={3} />
  </Section>

  <Section title={t("about.features_categories.title", locale)} description={t("about.features_categories.subtitle", locale)} width="wide" muted>
    <FeatureGrid items={categoryItems} columns={3} />
  </Section>

  <Section title={t("about.locations.title", locale)} description={t("about.locations.tagline", locale)} width="wide">
    <FeatureGrid items={locations} columns={4} />
  </Section>

  <Section width="wide">
    <CtaBanner
      title={t("about.support.title", locale)}
      description={t("about.support.tagline", locale)}
      action={{ label: support[0]?.title || "Support", href: `/${locale}/contact` }}
    />
  </Section>
</Layout>

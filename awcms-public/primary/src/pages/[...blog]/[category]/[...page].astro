---
import type { InferGetStaticPropsType, GetStaticPaths } from "astro";
import { defaultLocale } from "~/utils/i18n";
import { getStaticPathsBlogCategory } from "~/utils/blog";

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogCategory({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths> & {
  category: Record<string, string>;
};

const { page, category } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;
const query = new URLSearchParams({ category: category.slug });
if (currentPage > 1) query.set("page", String(currentPage));
const target = `/${defaultLocale}/blogs?${query.toString()}`;
---

<meta http-equiv="refresh" content={`0;url=${target}`} />
<script is:inline define:vars={{ target }}>
  window.location.href = target;
</script>

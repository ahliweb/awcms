---
interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  tagline?: string;
  isDark?: boolean;
  classes?: Record<string, string>;
  bg?: string;
}

const {
  id,
  title,
  subtitle,
  tagline,
  isDark = false,
  classes = {},
  bg,
} = Astro.props;
---

<section id={id} class:list={["py-14 sm:py-18 lg:py-24", isDark && "bg-slate-950 text-white", classes?.container]}>
  {bg && <Fragment set:html={bg} />}
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    {
      (tagline || title || subtitle) && (
        <header class="mb-10 flex flex-col gap-3">
          {tagline && <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary">{tagline}</p>}
          {title && <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>}
          {subtitle && <p class="max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300">{subtitle}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>

---
import BlockShell from "~/components/puck-blocks/BlockShell.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";

const { items = [], id, isDark, classes, bg } = Astro.props;

type PricingFeature = {
  text?: string;
};

type PricingItem = {
  title?: string;
  description?: string;
  price?: string;
  period?: string;
  features?: PricingFeature[];
  callToAction?: string;
  buttonText?: string;
  isPopular?: boolean;
  ribbonTitle?: string;
};

type PricingCard = {
  title: string;
  subtitle?: string;
  price?: string;
  period?: string;
  items: Array<{ description?: string; icon: string }>;
  hasRibbon?: boolean;
  ribbonTitle?: string;
};

// Map Puck items to Pricing widget props
const safeItems = Array.isArray(items) ? (items as PricingItem[]) : [];
const prices: PricingCard[] = safeItems
  .filter((item) => item.title)
  .map((item) => ({
    title: item.title as string,
    subtitle: item.description,
    price: item.price,
    period: item.period,
    items:
      item.features?.map((feature: PricingFeature) => ({
        description: feature.text,
        icon: "tabler:check",
      })) || [],
    hasRibbon: item.isPopular,
    ribbonTitle: item.ribbonTitle,
  }));
---

<BlockShell id={id} isDark={isDark} classes={classes} bg={bg}>
  <FeatureGrid items={prices.map((item: PricingCard) => ({
    title: item.title,
    description: [item.subtitle, ...item.items.map((feature: { description?: string }) => feature.description)].filter(Boolean).join(" | "),
    icon: item.hasRibbon ? item.ribbonTitle || "Popular" : item.price ? `${item.price}${item.period || ""}` : "Plan",
  }))} columns={3} />
</BlockShell>

---
import BlockShell from "~/components/puck-blocks/BlockShell.astro";
import FaqList from "~/components/public/FaqList.astro";

const {
  title,
  subtitle,
  tagline,
  items = [],
  id,
  isDark,
  classes,
  bg,
} = Astro.props;

type AccordionItem = {
  title?: string;
  content?: string;
};

type FaqEntry = {
  question: string;
  answer: string;
};

// Map Puck items to FAQs widget props
// Puck items: { title, content }
// FAQs items: { title, description }
const safeItems = Array.isArray(items) ? (items as AccordionItem[]) : [];
const faqItems: FaqEntry[] = safeItems
  .filter((item) => item.title && item.content)
  .map((item) => ({
    question: item.title as string,
    answer: item.content as string,
  }));
---

<BlockShell title={title} subtitle={subtitle} tagline={tagline} id={id} isDark={isDark} classes={classes} bg={bg}>
  <FaqList items={faqItems} />
</BlockShell>

---
import BlockShell from "~/components/puck-blocks/BlockShell.astro";
import StatGrid from "~/components/public/StatGrid.astro";

const { items = [], id, isDark, classes, bg } = Astro.props;

type StatsItem = {
  value?: string | number;
  label?: string;
  icon?: string;
};

// Map Puck items to Stats widget props
const safeItems = Array.isArray(items) ? (items as StatsItem[]) : [];
const stats = safeItems.map((item) => ({
  amount: item.value,
  title: item.label,
  icon: item.icon || "tabler:users",
}));
---

<BlockShell id={id} isDark={isDark} classes={classes} bg={bg}>
  <StatGrid items={stats.map((item) => ({ value: String(item.amount ?? ""), label: item.title }))} />
</BlockShell>

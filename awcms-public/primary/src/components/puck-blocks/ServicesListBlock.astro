---
import { createClientFromEnv } from "~/lib/supabase";
import { getPublicTenantId } from "~/lib/publicTenant";
import { getLocale, t } from "~/utils/i18n";
import BlockShell from "~/components/puck-blocks/BlockShell.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import type { Item } from "~/types";

interface Props {
    count?: number;
    layout?: "grid" | "list";
    columns?: number;
    title?: string;
    subtitle?: string;
    tagline?: string;
}

type ServiceCard = {
    title: string;
    description?: string;
    icon: string;
};

const { count = 6, columns = 3, title, subtitle, tagline } = Astro.props;

const tenantId = getPublicTenantId();
const supabase = createClientFromEnv(import.meta.env);
const locale = getLocale(Astro.url);

let services: Item[] = [];

if (tenantId && supabase) {
    try {
        const { data: servicesData } = await supabase
            .from("services")
            .select("*")
            .eq("tenant_id", tenantId)
            .eq("status", "published")
            .is("deleted_at", null)
            .order("display_order", { ascending: true })
            .limit(count);

        if (servicesData) {
            services = servicesData.map((s) => ({
                title: s.title,
                description: s.description,
                icon: s.icon || "tabler:check", // Fallback if no icon in DB
            }));
        }
    } catch (e) {
        console.error("[ServicesListBlock] Error fetching services:", e);
    }
}

const serviceCards: ServiceCard[] = services
    .filter((item) => item.title)
    .map((item) => ({
        title: item.title as string,
        description: item.description,
        icon: item.icon || "service",
    }));
---

{
    serviceCards.length > 0 ? (
        <BlockShell title={title || t("home.services.title", locale)} subtitle={subtitle || t("home.services.subtitle", locale)} tagline={tagline || t("home.services.tagline", locale)}>
            <FeatureGrid items={serviceCards} columns={columns === 2 ? 2 : columns === 4 ? 4 : 3} />
        </BlockShell>
    ) : (
        <div class="text-center p-8 bg-slate-50 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded-lg border border-dashed border-slate-300 dark:border-slate-700">
            No services found.
        </div>
    )
}

---
import { createClientFromEnv } from "~/lib/supabase";
import { ChevronDown } from "lucide-react";

interface Props {
  style?: "horizontal" | "vertical";
  alignment?: "left" | "center" | "right";
  showDropdowns?: boolean;
  fontSize?: "sm" | "base" | "lg";
  gap?: number;
  linkColor?: string;
}

interface MenuItem {
  id: string;
  parent_id: string | null;
  label: string;
  url: string;
  target?: string;
  icon?: string;
  order: number;
  children?: MenuItem[];
  [key: string]: unknown;
}

const {
  style = "horizontal",
  alignment = "left",
  showDropdowns = true,
  fontSize = "base",
  gap = 8,
  linkColor,
} = Astro.props;

const supabase = createClientFromEnv(import.meta.env);
let menus: MenuItem[] = [];

if (supabase) {
  try {
    const { data } = await supabase
      .from("menus")
      .select("*")
      .eq("is_active", true)
      .eq("is_public", true)
      .is("deleted_at", null)
      .order("order", { ascending: true });

    if (data) {
      // Build tree structure
      const menuMap: Record<string, MenuItem> = {};
      data.forEach((m: MenuItem) => (menuMap[m.id] = { ...m, children: [] }));

      const rootMenus: MenuItem[] = [];
      data.forEach((m: MenuItem) => {
        if (m.parent_id && menuMap[m.parent_id]) {
          menuMap[m.parent_id].children?.push(menuMap[m.id]);
        } else {
          rootMenus.push(menuMap[m.id]);
        }
      });

      // Sort children
      rootMenus.forEach((r) => r.children?.sort((a, b) => a.order - b.order));
      menus = rootMenus;
    }
  } catch (e) {
    console.error("[NavigationBlock] Error fetching menus:", e);
  }
}

const alignmentClass = {
  left: "justify-start",
  center: "justify-center",
  right: "justify-end",
};

const fontSizeClass = {
  sm: "text-sm",
  base: "text-base",
  lg: "text-lg",
};
---

{
  menus.length === 0 ? (
    <nav class="py-4 text-center text-slate-400 text-sm">
      No menu items available
    </nav>
  ) : (
    <nav class="py-4">
      {style === "vertical" ? (
        <ul
          class={`flex flex-col ${fontSizeClass[fontSize]}`}
          style={{ gap: `${gap}px` }}
        >
          {menus.map((menu) => (
            <li>
              <a
                href={menu.url}
                class="block px-3 py-2 rounded-lg text-slate-700 dark:text-slate-200 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors font-medium"
                style={{ color: linkColor }}
              >
                {menu.label}
              </a>
              {showDropdowns && menu.children && menu.children.length > 0 && (
                <ul class="pl-4 mt-1 space-y-1 border-l-2 border-slate-100 dark:border-slate-700 ml-3">
                  {menu.children.map((child) => (
                    <li>
                      <a
                        href={child.url}
                        class="block px-3 py-1.5 text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                        style={{ color: linkColor }}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <ul
          class={`flex flex-wrap ${alignmentClass[alignment]} ${fontSizeClass[fontSize]}`}
          style={{ gap: `${gap * 2}px` }}
        >
          {menus.map((menu) => {
            const hasChildren = menu.children && menu.children.length > 0;
            return (
              <li class="relative group z-20">
                <a
                  href={menu.url}
                  class="flex items-center gap-1 px-3 py-2 rounded-lg text-slate-700 dark:text-slate-200 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors font-medium"
                  style={{ color: linkColor }}
                >
                  {menu.label}
                  {hasChildren && showDropdowns && (
                    <ChevronDown
                      className="w-3.5 h-3.5 opacity-70"
                      client:load
                    />
                  )}
                </a>

                {hasChildren && showDropdowns && (
                  <div class="absolute top-full left-0 mt-1 w-48 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200">
                    <div class="p-1">
                      {menu.children?.map((child) => (
                        <a
                          href={child.url}
                          class="block px-3 py-2 text-sm text-slate-600 dark:text-slate-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-colors"
                          style={{ color: linkColor }}
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      )}
    </nav>
  )
}

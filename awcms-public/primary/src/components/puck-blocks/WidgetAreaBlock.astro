---
import WidgetArea from "~/components/common/WidgetArea.astro";

interface Props {
  area?: string;
  title?: string;
  [key: string]: unknown;
}

const { area, title } = Astro.props;
---

<WidgetArea
  area={area || "default"}
  title={title}
  emptyMessage={area ? `Widget Area: ${area} (Empty)` : ""}
/>

---
import BlockShell from "~/components/puck-blocks/BlockShell.astro";
import FeatureGrid from "~/components/public/FeatureGrid.astro";
import SplitSection from "~/components/public/SplitSection.astro";

interface Props {
    layout?: "grid" | "image-side";
    title?: string;
    subtitle?: string;
    tagline?: string;
    items?: Array<{
        title?: string;
        description?: string;
        icon?: string;
        link?: string;
    }>;
    columns?: number;
    image?: string;
    isReversed?: boolean;
    id?: string;
    isDark?: boolean;
    classes?: Record<string, string>;
    bg?: string;
}

type FeatureItem = {
  title: string;
  description?: string;
  icon: string;
};

const {
    layout = "grid",
    title,
    subtitle,
    tagline,
    items = [],
    columns = 3,
    image,
    isReversed,
    id,
    isDark = false,
    classes = {},
    bg,
} = Astro.props;

const mappedItems: FeatureItem[] = items
    .filter((item) => item.title)
    .map((item) => ({
        title: item.title as string,
        description: item.description,
        icon: item.icon || "feature",
    }));
---

<BlockShell id={id} title={title} subtitle={subtitle} tagline={tagline} isDark={isDark} classes={classes} bg={bg}>
  {
    layout === "image-side" ? (
      <SplitSection
        title={title || ""}
        description={subtitle}
        items={mappedItems}
        image={image ? { src: image, alt: title || "Feature Image" } : undefined}
        reverse={isReversed}
      />
    ) : (
      <FeatureGrid items={mappedItems} columns={columns === 2 ? 2 : columns === 4 ? 4 : 3} />
    )
  }
</BlockShell>

---
interface Action {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  action?: Action;
}

const { title, description, action } = Astro.props;
---

<div class="rounded-[2rem] bg-slate-950 px-8 py-10 text-white shadow-2xl shadow-slate-950/20 dark:border dark:border-slate-800 dark:bg-slate-900">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h3>
      {description && <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">{description}</p>}
    </div>
    {
      action && (
        <a href={action.href} class="inline-flex rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100">
          {action.label}
        </a>
      )
    }
  </div>
</div>

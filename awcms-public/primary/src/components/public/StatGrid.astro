---
interface StatItem {
  value: string;
  label?: string;
}

interface Props {
  items: StatItem[];
}

const { items = [] } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
  {items.map((item) => (
    <div class="rounded-3xl border border-slate-200/70 bg-white px-6 py-8 text-center shadow-sm shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-950 dark:shadow-none">
      <p class="text-3xl font-bold tracking-tight text-slate-950 dark:text-slate-50 sm:text-4xl">{item.value}</p>
      {item.label && <p class="mt-2 text-sm uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">{item.label}</p>}
    </div>
  ))}
</div>

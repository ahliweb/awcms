---
interface Testimonial {
  quote: string;
  name: string;
  role?: string;
}

interface Props {
  items: Testimonial[];
}

const { items = [] } = Astro.props;
---

<div class="grid gap-5 lg:grid-cols-3">
  {items.map((item) => (
    <figure class="rounded-3xl border border-slate-200/70 bg-white p-6 shadow-sm shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-950 dark:shadow-none">
      <blockquote class="text-base leading-7 text-slate-700 dark:text-slate-200">“{item.quote}”</blockquote>
      <figcaption class="mt-6 border-t border-slate-200/70 pt-4 dark:border-slate-800">
        <p class="font-semibold text-slate-950 dark:text-slate-100">{item.name}</p>
        {item.role && <p class="text-sm text-slate-500 dark:text-slate-400">{item.role}</p>}
      </figcaption>
    </figure>
  ))}
</div>

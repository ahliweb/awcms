---
interface Action {
  label: string;
  href: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  image?: { src: string; alt: string };
  align?: "left" | "center";
  actions?: Action[];
}

const {
  eyebrow,
  title,
  description,
  image,
  align = "left",
  actions = [],
} = Astro.props;

const center = align === "center";
---

<section class="py-16 sm:py-20 lg:py-28">
  <div class:list={["mx-auto grid max-w-7xl gap-12 px-6 sm:px-8", image && !center ? "lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)] lg:items-center" : "max-w-5xl", center && "text-center"]}>
    <div class:list={["flex flex-col gap-5", center && "items-center"]}>
      {eyebrow && <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary">{eyebrow}</p>}
      <h1 class="max-w-4xl text-4xl font-bold tracking-tight text-slate-950 dark:text-slate-50 sm:text-5xl lg:text-6xl" set:html={title} />
      {description && (
        <p class="max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300" set:html={description} />
      )}
      {
        actions.length > 0 && (
          <div class:list={["flex flex-wrap gap-3 pt-2", center && "justify-center"]}>
            {actions.map((action) => (
              <a
                href={action.href}
                class:list={[
                  "inline-flex items-center rounded-full px-5 py-3 text-sm font-semibold transition",
                  action.variant === "secondary"
                    ? "border border-slate-300 text-slate-700 hover:border-primary/40 hover:text-primary dark:border-slate-700 dark:text-slate-200"
                    : "bg-primary text-white hover:bg-primary/90",
                ]}
              >
                {action.label}
              </a>
            ))}
          </div>
        )
      }
      <slot name="meta" />
    </div>

    {
      image && (
        <div class:list={[center && "mx-auto max-w-4xl", "overflow-hidden rounded-[2rem] border border-slate-200/70 bg-white shadow-xl shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-900 dark:shadow-none"]}>
          <img src={image.src} alt={image.alt} class="h-full w-full object-cover" loading="eager" />
        </div>
      )
    }

    <slot />
  </div>
</section>

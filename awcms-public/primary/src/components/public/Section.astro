---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  align?: "left" | "center";
  width?: "default" | "wide" | "narrow";
  padded?: boolean;
  muted?: boolean;
}

const {
  id,
  eyebrow,
  title,
  description,
  align = "left",
  width = "default",
  padded = true,
  muted = false,
} = Astro.props;

const widthClass =
  width === "wide"
    ? "max-w-7xl"
    : width === "narrow"
      ? "max-w-4xl"
      : "max-w-6xl";

const alignClass = align === "center" ? "text-center items-center" : "text-left items-start";
---

<section id={id} class:list={[padded && "py-14 sm:py-18 lg:py-24", muted && "bg-slate-50/70 dark:bg-slate-900/40"]}>
  <div class:list={["mx-auto px-6 sm:px-8", widthClass]}>
    {
      (eyebrow || title || description) && (
        <header class:list={["mb-10 flex flex-col gap-3", alignClass]}>
          {eyebrow && (
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary">
              {eyebrow}
            </p>
          )}
          {title && (
            <h2 class="max-w-4xl text-3xl font-bold tracking-tight text-slate-950 dark:text-slate-50 sm:text-4xl">
              {title}
            </h2>
          )}
          {description && (
            <p class="max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg">
              {description}
            </p>
          )}
        </header>
      )
    }

    <slot />
  </div>
</section>

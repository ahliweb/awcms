---
interface Item {
  title: string;
  description?: string;
  icon?: string;
}

interface Props {
  items: Item[];
  columns?: 2 | 3 | 4;
}

const { items = [], columns = 3 } = Astro.props;
const columnClass =
  columns === 2
    ? "md:grid-cols-2"
    : columns === 4
      ? "md:grid-cols-2 xl:grid-cols-4"
      : "md:grid-cols-2 xl:grid-cols-3";
---

<div class:list={["grid gap-5", columnClass]}>
  {items.map((item) => (
    <article class="rounded-3xl border border-slate-200/70 bg-white p-6 shadow-sm shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-950 dark:shadow-none">
      {item.icon && <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-primary">{item.icon}</p>}
      <h3 class="text-lg font-semibold tracking-tight text-slate-950 dark:text-slate-100">{item.title}</h3>
      {item.description && <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{item.description}</p>}
    </article>
  ))}
</div>

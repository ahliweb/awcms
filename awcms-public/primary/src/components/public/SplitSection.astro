---
interface DetailItem {
  title: string;
  description?: string;
}

interface Props {
  title: string;
  description?: string;
  items?: DetailItem[];
  image?: { src: string; alt: string };
  reverse?: boolean;
}

const { title, description, items = [], image, reverse = false } = Astro.props;
---

<div class:list={["grid gap-10 lg:grid-cols-2 lg:items-center", reverse && "lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1"]}>
  <div>
    <h3 class="text-2xl font-bold tracking-tight text-slate-950 dark:text-slate-50 sm:text-3xl">{title}</h3>
    {description && <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">{description}</p>}
    {items.length > 0 && (
      <div class="mt-6 grid gap-4">
        {items.map((item) => (
          <div class="rounded-2xl border border-slate-200/70 bg-white px-5 py-4 dark:border-slate-800 dark:bg-slate-950">
            <p class="font-medium text-slate-950 dark:text-slate-100">{item.title}</p>
            {item.description && <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{item.description}</p>}
          </div>
        ))}
      </div>
    )}
  </div>
  {
    image && (
      <div class="overflow-hidden rounded-[2rem] border border-slate-200/70 bg-white shadow-lg shadow-slate-200/30 dark:border-slate-800 dark:bg-slate-950 dark:shadow-none">
        <img src={image.src} alt={image.alt} class="h-full w-full object-cover" loading="lazy" />
      </div>
    )
  }
</div>

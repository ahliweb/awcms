---
import { createClientFromEnv } from "~/lib/supabase";
import { getPublicTenantId } from "~/lib/publicTenant";
import WidgetRenderer from "~/components/common/WidgetRenderer.astro";
import {
  getWidgetsByArea,
  getWidgetsByAreaSlug,
  type WidgetData,
} from "~/lib/widgets";

interface Props {
  area: string;
  title?: string;
  class?: string;
  emptyMessage?: string;
}

const {
  area,
  title,
  class: className = "",
  emptyMessage = "",
} = Astro.props;

const supabase = createClientFromEnv(import.meta.env);
const tenantId = getPublicTenantId();

let widgets: WidgetData[] = [];

if (supabase && area && tenantId) {
  try {
    widgets = await getWidgetsByAreaSlug(supabase, area, tenantId);
    if (widgets.length === 0) {
      widgets = await getWidgetsByArea(supabase, area, tenantId);
    }
  } catch (error) {
    console.error(`[WidgetArea] Failed to resolve area "${area}":`, error);
  }
}
---

<section class:list={["widget-area space-y-6", className]} data-widget-area={area}>
  {
    title && (
      <header>
        <h2 class="text-xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">
          {title}
        </h2>
      </header>
    )
  }

  {
    widgets.length > 0 ? (
      widgets.map((widget) => <WidgetRenderer widget={widget} />)
    ) : emptyMessage ? (
      <div class="rounded-2xl border border-dashed border-slate-300/70 px-4 py-6 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
        {emptyMessage}
      </div>
    ) : null
  }
</section>

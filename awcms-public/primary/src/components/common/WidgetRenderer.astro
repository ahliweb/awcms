---
/**
 * WidgetRenderer.astro - Server-side renderer for dynamic widgets from Supabase.
 *
 * Renders widgets based on their type and configuration.
 * Supports common widget types with Tailwind styling.
 */
import type { WidgetData } from "~/lib/widgets";
import { createClientFromEnv } from "~/lib/supabase";
import { getPublicTenantId } from "~/lib/publicTenant";
import { getLocale } from "~/utils/i18n";

export interface Props {
  /** Widget data object */
  widget: WidgetData;
  /** Optional CSS class for the container */
  class?: string;
}

const { widget, class: className = "" } = Astro.props;

const { type, name, config, content, show_title, custom_classes } = widget;
const rawEmdashPayload = widget.raw_emdash_payload || null;
const emdashComponentId = rawEmdashPayload && typeof rawEmdashPayload === 'object' ? rawEmdashPayload.componentId : null;
type PortableTextChild = { text?: string };
type PortableTextBlock = { children?: PortableTextChild[] };

const getPortableTextText = (value: PortableTextBlock[] | unknown) => {
  if (!Array.isArray(value)) return "";
  return value
    .map((block) => Array.isArray(block?.children)
      ? block.children.map((child: PortableTextChild) => child?.text || "").join("")
      : "")
    .filter(Boolean)
    .join("\n\n");
};

const effectiveType = emdashComponentId === "core:archives"
  ? "archives"
  : emdashComponentId === "core:recent-posts"
    ? "recent_posts"
    : emdashComponentId === "core:categories"
      ? "categories"
      : emdashComponentId === "core:tags"
        ? "tags"
        : emdashComponentId === "core:search"
          ? "search"
          : type;

const contentText = type === "content"
  ? getPortableTextText(content || rawEmdashPayload?.content)
  : "";

const supabase = createClientFromEnv(import.meta.env);
const tenantId = getPublicTenantId();
const locale = getLocale(Astro.url);

type BlogWidgetPost = {
  id: string;
  title: string;
  slug: string;
  published_at: string | null;
  created_at: string;
};

type NamedTerm = {
  id: string;
  name: string;
  slug: string;
};

const recentPosts: BlogWidgetPost[] = [];
const categories: NamedTerm[] = [];
const tags: NamedTerm[] = [];
const archives: Array<{ label: string; href: string; count: number }> = [];

if (supabase && effectiveType === "recent_posts") {
  let query = supabase
    .from("blogs")
    .select("id, title, slug, published_at, created_at")
    .eq("status", "published")
    .is("deleted_at", null)
    .order("published_at", { ascending: false })
    .limit(5);

  query = tenantId
    ? query.or(`tenant_id.eq.${tenantId},tenant_id.is.null`)
    : query.is("tenant_id", null);

  const { data } = await query;
  recentPosts.push(...((data || []) as BlogWidgetPost[]));
}

if (supabase && effectiveType === "categories") {
  let query = supabase
    .from("categories")
    .select("id, name, slug")
    .is("deleted_at", null)
    .order("name", { ascending: true })
    .limit(12);

  query = tenantId
    ? query.or(`tenant_id.eq.${tenantId},tenant_id.is.null`)
    : query.is("tenant_id", null);

  const { data } = await query;
  categories.push(...((data || []) as NamedTerm[]));
}

if (supabase && effectiveType === "tags") {
  let query = supabase
    .from("tags")
    .select("id, name, slug")
    .is("deleted_at", null)
    .order("name", { ascending: true })
    .limit(20);

  query = tenantId
    ? query.or(`tenant_id.eq.${tenantId},tenant_id.is.null`)
    : query.is("tenant_id", null);

  const { data } = await query;
  tags.push(...((data || []) as NamedTerm[]));
}

if (supabase && effectiveType === "archives") {
  let query = supabase
    .from("blogs")
    .select("published_at, created_at")
    .eq("status", "published")
    .is("deleted_at", null)
    .order("published_at", { ascending: false })
    .limit(50);

  query = tenantId
    ? query.or(`tenant_id.eq.${tenantId},tenant_id.is.null`)
    : query.is("tenant_id", null);

  const { data } = await query;
  const grouped = new Map<string, { label: string; href: string; count: number }>();

  for (const row of (data || []) as Array<{ published_at: string | null; created_at: string }>) {
    const source = row.published_at || row.created_at;
    if (!source) continue;
    const date = new Date(source);
    if (Number.isNaN(date.getTime())) continue;

    const year = date.getUTCFullYear();
    const month = String(date.getUTCMonth() + 1).padStart(2, "0");
    const key = `${year}-${month}`;
    const label = date.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
    });

    const existing = grouped.get(key);
    if (existing) {
      existing.count += 1;
    } else {
        grouped.set(key, {
          label,
          href: `/${locale}/blogs?archive=${key}`,
          count: 1,
        });
    }
  }

  archives.push(...grouped.values());
}

// Prepare typed data for specific widgets to avoid casting in template
const linkItems =
  type === "links" && Array.isArray(config?.items)
    ? (config.items as Array<{ title: string; url: string; icon?: string }>)
    : [];

const socialLinks =
  type === "social" && Array.isArray(config?.links)
    ? (config.links as Array<{ platform: string; url: string }>)
    : [];

/**
 * Get widget container classes based on type
 */
function getContainerClasses(widgetType: string): string {
  const baseClasses =
    "widget p-4 rounded-xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700";

  switch (widgetType) {
    case "featured":
      return `${baseClasses} bg-gradient-to-br from-primary/5 to-primary/10`;
    case "cta":
      return `${baseClasses} bg-primary text-white`;
    case "minimal":
      return "widget py-2";
    default:
      return baseClasses;
  }
}
---

<div class:list={[getContainerClasses(effectiveType), custom_classes, className]}>
  {
    show_title && name && (
      <h3 class="text-lg font-semibold mb-3 text-slate-800 dark:text-slate-200">
        {name}
      </h3>
    )
  }

  <div class="widget-content">
    {
      effectiveType === "text" && (
        <div
          class="prose prose-sm dark:prose-invert max-w-none"
          set:html={content || ""}
        />
      )
    }

      {effectiveType === "html" && <div set:html={content || ""} />}

      {
        effectiveType === "content" && contentText && (
          <div class="space-y-3 text-sm leading-6 text-slate-600 dark:text-slate-300 whitespace-pre-line">
            {contentText}
          </div>
        )
      }

      {
        effectiveType === "search" && (
          <form action={`/${locale}/search`} method="GET" class="space-y-3">
            <input
              type="search"
              name="q"
              placeholder="Search posts"
              class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm dark:border-slate-700 dark:bg-slate-900"
            />
            <button
              type="submit"
              class="inline-flex rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary/90"
            >
              Search
            </button>
          </form>
        )
      }

    {
      effectiveType === "image" && config?.src && (
        <figure>
          <img
            src={config.src as string}
            alt={(config.alt as string) || ""}
            class="w-full rounded-lg"
            loading="lazy"
          />
          {config.caption && (
            <figcaption class="mt-2 text-sm text-slate-500 dark:text-slate-400 text-center">
              {config.caption}
            </figcaption>
          )}
        </figure>
      )
    }

    {
      effectiveType === "links" && linkItems.length > 0 && (
        <ul class="space-y-2">
          {linkItems.map((item) => (
            <li>
              <a
                href={item.url}
                class="flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors"
              >
                {item.icon && <span class="w-4 h-4">{item.icon}</span>}
                <span>{item.title}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }

    {
      effectiveType === "recent_posts" && (
        <div class="space-y-3">
          {recentPosts.length > 0 ? (
            recentPosts.map((post) => (
              <a
                href={`/${locale}/blogs/${post.slug}`}
                class="block rounded-xl border border-slate-200/70 px-3 py-3 transition hover:border-primary/40 hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800/70"
              >
                <p class="text-sm font-medium text-slate-900 dark:text-slate-100">
                  {post.title}
                </p>
                <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                  {new Date(post.published_at || post.created_at).toLocaleDateString(
                    "en-US",
                    {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    },
                  )}
                </p>
              </a>
            ))
          ) : (
            <p class="text-sm text-slate-500 dark:text-slate-400 italic">
              No recent posts found.
            </p>
          )}
        </div>
      )
    }

    {
      effectiveType === "categories" && (
        <div class="flex flex-wrap gap-2">
          {categories.length > 0 ? (
            categories.map((category) => (
              <a
                href={`/${locale}/blogs?category=${category.slug}`}
                class="rounded-full border border-slate-200 px-3 py-1 text-xs font-medium text-slate-700 transition hover:border-primary/40 hover:text-primary dark:border-slate-700 dark:text-slate-300"
              >
                {category.name}
              </a>
            ))
          ) : (
            <p class="text-sm text-slate-500 dark:text-slate-400 italic">
              No categories found.
            </p>
          )}
        </div>
      )
    }

    {
      effectiveType === "tags" && (
        <div class="flex flex-wrap gap-2">
          {tags.length > 0 ? (
            tags.map((tag) => (
              <a
                href={`/${locale}/blogs?tag=${tag.slug}`}
                class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 transition hover:bg-primary/10 hover:text-primary dark:bg-slate-800 dark:text-slate-300"
              >
                #{tag.name}
              </a>
            ))
          ) : (
            <p class="text-sm text-slate-500 dark:text-slate-400 italic">
              No tags found.
            </p>
          )}
        </div>
      )
    }

    {
      effectiveType === "social" && socialLinks.length > 0 && (
        <div class="flex gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-colors"
              aria-label={social.platform}
            >
              <span class="text-sm font-medium uppercase">
                {social.platform.charAt(0)}
              </span>
            </a>
          ))}
        </div>
      )
    }

    {
      effectiveType === "cta" && (
        <div class="text-center">
          {config?.description && (
            <p class="mb-4 text-white/90">{config.description}</p>
          )}
          {config?.button_text && config?.button_url && (
            <a
              href={config.button_url as string}
              class="inline-block px-6 py-2 bg-white text-primary font-semibold rounded-lg hover:bg-slate-100 transition-colors"
            >
              {config.button_text}
            </a>
          )}
        </div>
      )
    }

    {
      effectiveType === "newsletter" && (
        <form class="space-y-3">
          {config?.description && (
            <p class="text-sm text-slate-600 dark:text-slate-400">
              {config.description}
            </p>
          )}
          <div class="flex gap-2">
            <input
              type="email"
              placeholder="Enter your email"
              class="flex-1 px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
            />
            <button
              type="submit"
              class="px-4 py-2 bg-primary text-white font-medium rounded-lg hover:bg-primary/90 transition-colors text-sm"
            >
              Subscribe
            </button>
          </div>
        </form>
      )
    }

    {
      effectiveType === "map" && config?.embed_url && (
        <div class="aspect-video rounded-lg overflow-hidden">
          <iframe
            src={config.embed_url as string}
            class="w-full h-full border-0"
            loading="lazy"
            allowfullscreen
          />
        </div>
      )
    }

    {
      effectiveType === "contact" && (
        <div class="space-y-3 text-sm">
          {config?.address && (
            <div class="flex items-start gap-2">
              <span class="text-slate-400">📍</span>
              <span class="text-slate-600 dark:text-slate-400">
                {config.address}
              </span>
            </div>
          )}
          {config?.phone && (
            <div class="flex items-center gap-2">
              <span class="text-slate-400">📞</span>
              <a
                href={`tel:${config.phone}`}
                class="text-slate-600 dark:text-slate-400 hover:text-primary"
              >
                {config.phone}
              </a>
            </div>
          )}
          {config?.email && (
            <div class="flex items-center gap-2">
              <span class="text-slate-400">✉️</span>
              <a
                href={`mailto:${config.email}`}
                class="text-slate-600 dark:text-slate-400 hover:text-primary"
              >
                {config.email}
              </a>
            </div>
          )}
        </div>
      )
    }

      {
        effectiveType === "archives" && (
          <div class="space-y-3">
            {archives.length > 0 ? (
              archives.map((archive) => (
                <a
                  href={archive.href}
                  class="flex items-center justify-between rounded-xl border border-slate-200/70 px-3 py-2 text-sm transition hover:border-primary/40 hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800/70"
                >
                  <span class="text-slate-700 dark:text-slate-300">{archive.label}</span>
                  <span class="text-slate-500 dark:text-slate-400">{archive.count}</span>
                </a>
              ))
            ) : (
              <p class="text-sm text-slate-500 dark:text-slate-400 italic">
                No archive entries found.
              </p>
            )}
          </div>
        )
      }

    {/* Fallback for unknown types */}
    {
      ![
        "text",
        "html",
        "content",
        "search",
        "image",
        "links",
        "recent_posts",
        "categories",
        "archives",
        "tags",
        "social",
        "cta",
        "newsletter",
        "map",
        "contact",
      ].includes(type) && (
        <div class="text-sm text-slate-500 dark:text-slate-400 italic">
          Widget type "{type}" - Content rendering available soon.
        </div>
      )
    }
  </div>
</div>

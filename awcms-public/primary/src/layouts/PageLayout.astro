---
import Layout from "~/layouts/Layout.astro";
import Header from "~/components/widgets/Header.astro";
import Footer from "~/components/widgets/Footer.astro";
import Announcement from "~/components/widgets/Announcement.astro";

import {
  headerData as fallbackHeaderData,
  footerData as fallbackFooterData,
} from "~/navigation";
import { createClientFromEnv } from "~/lib/supabase";
import { getPublicSettings } from "~/lib/publicSettings";
import {
  getFooterMenu,
  getHeaderMenu,
  localizePublicUrl,
  type HeaderLink,
  mapMenuItemsToFooterLinks,
  mapMenuItemsToHeaderLinks,
} from "~/lib/menu";
import { getActivePublicModules } from "~/lib/extension_registry";
import { getPublicTenantId } from "~/lib/publicTenant";
import {
  createPublicPageContext,
  type PublicContentRef,
} from "~/lib/publicPageContext";

import type { MetaData } from "~/types";

export interface Props {
  metadata?: MetaData;
  pageType?: string;
  contentRef?: PublicContentRef;
}

import { getLocale } from "~/utils/i18n";

const { metadata, pageType = "website", contentRef } = Astro.props;
const tenantId = getPublicTenantId();
const supabase = createClientFromEnv(import.meta.env);
const locale = getLocale(Astro.url);
const { siteInfo } = await getPublicSettings();
const pageContext = createPublicPageContext({
  metadata,
  pageType,
  locale,
  tenantId,
  content: contentRef,
});

let headerLinks: HeaderLink[] = fallbackHeaderData.links;
let footerLinks = fallbackFooterData.links;
let headerActions = fallbackHeaderData.actions;
let socialLinks = fallbackFooterData.socialLinks;
let secondaryLinks = fallbackFooterData.secondaryLinks.map(
  (link) => ({
    ...link,
    href: localizePublicUrl(link.href, locale),
  }),
);
let footNote = fallbackFooterData.footNote;

const parseJsonArray = (value: unknown) => {
  if (!value) return null;
  if (Array.isArray(value)) return value;
  if (typeof value === "string") {
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed : null;
    } catch {
      return null;
    }
  }
  return null;
};

const normalizedHeaderActions = parseJsonArray(
  siteInfo?.header_actions_json || siteInfo?.headerActions,
)
  ?.map((action) => {
    if (!action || typeof action !== "object") return null;
    const text = typeof action.text === "string" ? action.text : "";
    const href = typeof action.href === "string" ? action.href : "";
    if (!text || !href) return null;
    return {
      text,
      href: localizePublicUrl(href, locale),
      target: typeof action.target === "string" ? action.target : undefined,
    };
  })
  .filter(Boolean);

if (normalizedHeaderActions && normalizedHeaderActions.length > 0) {
  headerActions = normalizedHeaderActions;
}

const configuredPrimaryCtaLabel =
  (siteInfo?.primary_cta_label as string | undefined) ||
  (siteInfo?.primaryCtaLabel as string | undefined);
const configuredPrimaryCtaUrl =
  (siteInfo?.primary_cta_url as string | undefined) ||
  (siteInfo?.primaryCtaUrl as string | undefined);

if (configuredPrimaryCtaLabel && configuredPrimaryCtaUrl) {
  headerActions = [
    {
      text: configuredPrimaryCtaLabel,
      href: configuredPrimaryCtaUrl,
      target: configuredPrimaryCtaUrl.startsWith("http") ? "_blank" : undefined,
    },
  ];
}

const configuredFooterColumns = parseJsonArray(
  siteInfo?.footer_columns_json || siteInfo?.footerColumns,
)
  ?.map((column) => {
    if (!column || typeof column !== "object") return null;
    const title = typeof column.title === "string" ? column.title : "";
    const links = Array.isArray(column.links)
      ? column.links
          .map((link) => {
            if (!link || typeof link !== "object") return null;
            const text = typeof link.text === "string" ? link.text : "";
            const href = typeof link.href === "string" ? link.href : "";
            if (!text || !href) return null;
            return {
              text,
              href: localizePublicUrl(href, locale),
              ariaLabel:
                typeof link.ariaLabel === "string" ? link.ariaLabel : undefined,
              target: typeof link.target === "string" ? link.target : undefined,
              popup: Boolean(link.popup),
            };
          })
          .filter(Boolean)
      : [];
    if (!title && links.length === 0) return null;
    return { title, links };
  })
  .filter(Boolean);

if (configuredFooterColumns && configuredFooterColumns.length > 0) {
  footerLinks = configuredFooterColumns;
}

const configuredSecondaryLinks = parseJsonArray(
  siteInfo?.footer_secondary_links_json || siteInfo?.footerSecondaryLinks,
)
  ?.map((link) => {
    if (!link || typeof link !== "object") return null;
    const text = typeof link.text === "string" ? link.text : "";
    const href = typeof link.href === "string" ? link.href : "";
    if (!text || !href) return null;
    return {
      text,
      href: localizePublicUrl(href, locale),
      target: typeof link.target === "string" ? link.target : undefined,
      popup: Boolean(link.popup),
      ariaLabel: typeof link.ariaLabel === "string" ? link.ariaLabel : undefined,
    };
  })
  .filter(Boolean);

if (configuredSecondaryLinks && configuredSecondaryLinks.length > 0) {
  secondaryLinks = configuredSecondaryLinks;
}

const configuredSocialLinks = [
  {
    key: "social_twitter",
    altKey: "socialTwitter",
    ariaLabel: "X",
    icon: "tabler:brand-x",
  },
  {
    key: "social_instagram",
    altKey: "socialInstagram",
    ariaLabel: "Instagram",
    icon: "tabler:brand-instagram",
  },
  {
    key: "social_facebook",
    altKey: "socialFacebook",
    ariaLabel: "Facebook",
    icon: "tabler:brand-facebook",
  },
  {
    key: "social_youtube",
    altKey: "socialYoutube",
    ariaLabel: "Youtube",
    icon: "tabler:brand-youtube",
  },
]
  .map(({ key, altKey, ariaLabel, icon }) => {
    const href =
      (siteInfo?.[key] as string | undefined) ||
      (siteInfo?.[altKey] as string | undefined) ||
      "";
    if (!href) return null;
    return { ariaLabel, icon, href };
  })
  .filter(
    (item): item is { ariaLabel: string; icon: string; href: string } =>
      Boolean(item),
  );

if (configuredSocialLinks.length > 0) {
  socialLinks = configuredSocialLinks;
}

const configuredSocialLinksJson = parseJsonArray(
  siteInfo?.social_links_json || siteInfo?.socialLinks,
)
  ?.map((link) => {
    if (!link || typeof link !== "object") return null;
    const href = typeof link.href === "string" ? link.href : "";
    const ariaLabel = typeof link.ariaLabel === "string" ? link.ariaLabel : "";
    const icon = typeof link.icon === "string" ? link.icon : "";
    if (!href || !ariaLabel || !icon) return null;
    return { href, ariaLabel, icon };
  })
  .filter(
    (item): item is { ariaLabel: string; icon: string; href: string } =>
      Boolean(item),
  );

if (configuredSocialLinksJson && configuredSocialLinksJson.length > 0) {
  socialLinks = configuredSocialLinksJson;
}

if (typeof siteInfo?.footer_footnote === "string" && siteInfo.footer_footnote) {
  footNote = siteInfo.footer_footnote;
}

if (supabase && tenantId) {
  const headerItems = await getHeaderMenu(supabase, tenantId, locale);
  const footerItems = await getFooterMenu(supabase, tenantId, locale);

  if (headerItems.length > 0) {
    headerLinks = mapMenuItemsToHeaderLinks(headerItems, locale);
  }

  if (footerItems.length > 0) {
    footerLinks = mapMenuItemsToFooterLinks(footerItems, locale);
  }

  const publicModules = await getActivePublicModules(supabase, tenantId);
  type PublicModuleLink = { label: string; url: string };
  const moduleLinks = publicModules
    .filter((module: Partial<PublicModuleLink> | null | undefined): module is PublicModuleLink => Boolean(module?.url && module?.label))
    .map((module: PublicModuleLink) => ({
      text: module.label,
      href: localizePublicUrl(module.url, locale),
    }));

  if (moduleLinks.length > 0) {
    const moduleGroup = {
      text: locale === "id" ? "Ekstensi" : "Extensions",
      links: moduleLinks,
    };
    headerLinks = [...headerLinks, moduleGroup];
    footerLinks = [
      ...footerLinks,
      {
        title: locale === "id" ? "Ekstensi" : "Extensions",
        links: moduleLinks.map((link: HeaderLink) => ({ text: link.text || "", href: link.href || "#" })),
      },
    ];
  }
}
---

<Layout metadata={metadata} pageContext={pageContext}>
  <slot name="announcement">
    <Announcement />
  </slot>
  <slot name="header">
      <Header
        links={headerLinks}
        actions={headerActions}
        isSticky
        showToggleTheme
      />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
      <Footer
        links={footerLinks}
        secondaryLinks={secondaryLinks}
        socialLinks={socialLinks}
        footNote={footNote}
      />
  </slot>
</Layout>

{
  "name": "awcms-public-root",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "cd primary && bun run dev",
    "dev:primary": "cd primary && bun run dev",
    "dev:smandapbun": "cd smandapbun && bun run dev",
    "build": "bun run build:all",
    "build:primary": "cd primary && bun run build",
    "build:smandapbun": "cd smandapbun && bun run build",
    "build:all": "bun run build:primary && bun run build:smandapbun"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "bun@1.3.14"
}

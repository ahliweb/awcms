---
import SettingsManagedPage from "../../components/SettingsManagedPage.astro";
import BadgeCardGrid from "../../components/public/BadgeCardGrid.astro";
import { getProfilePageData } from "../../lib/api";

const profileData = await getProfilePageData();
const data = profileData?.competencyAlignment;

const getLocal = (str: any) => str?.id || str || "";
const getLocalArray = (arr: any) => arr?.id || arr || [];

const implementationItems = (data?.implementation?.items || []).map((item: any) => ({
  title: getLocal(item.category),
  badge: getLocal(item.progress),
  description: getLocalArray(item.activities).join("\n"),
}));
---

<SettingsManagedPage data={data} locale="id" backHref="/profil">
  {implementationItems.length > 0 && (
    <div class="mt-12 space-y-8">
      <h2 class="text-2xl font-bold font-heading text-primary">
        {getLocal(data?.implementation?.title) || "Implementasi"}
      </h2>

      <BadgeCardGrid items={implementationItems} columns={2} />
    </div>
  )}
</SettingsManagedPage>

---
import SettingsManagedPage from "../../components/SettingsManagedPage.astro";
import TimelineList from "../../components/public/TimelineList.astro";
import { getProfilePageData } from "../../lib/api";

const profileData = await getProfilePageData();
const data = profileData?.history;

const getLocal = (str: any) => str?.id || str || "";
const milestoneItems = (data?.milestones || []).map((milestone: any) => ({
  badge: String(milestone.year || ""),
  description: getLocal(milestone.event),
}));
---

<SettingsManagedPage data={data} locale="id" backHref="/profil">
  {milestoneItems.length > 0 && <TimelineList title="Milestones" items={milestoneItems} />}
</SettingsManagedPage>

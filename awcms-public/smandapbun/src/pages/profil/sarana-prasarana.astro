---
import SettingsManagedPage from "../../components/SettingsManagedPage.astro";
import BadgeCardGrid from "../../components/public/BadgeCardGrid.astro";
import { getProfilePageData } from "../../lib/api";

const profileData = await getProfilePageData();
const data = profileData?.facilities;

const getLocal = (str: any) => str?.id || str || "";
const facilityItems = (data?.items || []).map((item: any) => ({
  title: getLocal(item.name),
  badge: `Jumlah: ${item.count}`,
  secondaryBadge: `Kondisi: ${item.condition}`,
  description: item.description ? getLocal(item.description) : undefined,
}));
---

<SettingsManagedPage data={data} locale="id" backHref="/profil">
  {facilityItems.length > 0 && <BadgeCardGrid items={facilityItems} columns={3} />}
</SettingsManagedPage>

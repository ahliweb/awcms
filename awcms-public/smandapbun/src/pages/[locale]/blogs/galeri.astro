---
import Layout from "../../../layouts/Layout.astro";
import PageHero from "../../../components/public/PageHero.astro";
import GalleryArchiveContent from "../../../components/public/GalleryArchiveContent.astro";
import { t, getLocalizedValue, getLocalizedPath, type Locale } from "../../../utils/i18n";
import { getAdminPageBySlug, getGalleryData } from "../../../lib/api";
import { sanitizeHTML } from "../../../utils/sanitize";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const { locale } = Astro.params as { locale: Locale };
const galleryData = await getGalleryData();
const galleryPage = await getAdminPageBySlug("galeri", locale);
const { gallery } = galleryData;
const pageTitle = galleryPage?.title || getLocalizedValue(gallery.title, locale) || t("blogs.gallery", locale);
const pageDescription = galleryPage?.excerpt || undefined;
---

<Layout title={pageTitle} description={pageDescription} pageType="gallery_archive">
  <PageHero title={pageTitle} description={pageDescription} image="/images/backgrounds/hero-activity.webp" breadcrumbs={[{ href: getLocalizedPath("/", locale), label: t("nav.home", locale) }, { href: getLocalizedPath("/blogs", locale), label: t("blogs.title", locale) }, { label: t("blogs.gallery", locale) }]} testId="gallery-hero" />
  <GalleryArchiveContent locale={locale} pageHtml={galleryPage?.content ? sanitizeHTML(galleryPage.content) : null} />
</Layout>

---
import Layout from "../../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Section from "../../../components/public/Section.astro";
import BlogCard from "../../../components/public/BlogCard.astro";
import BlogSidebar from "../../../components/public/BlogSidebar.astro";
import {
  t,
  type Locale,
} from "../../../utils/i18n";
import { getPosts } from "../../../lib/api";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const { locale } = Astro.params as { locale: Locale };
const posts = await getPosts(100, locale);
// posts are already sorted by default from API
---

<Layout
  title={t("blogs.title", locale)}
  description={t("home.latest_blogs", locale)}
  pageType="blog_archive"
>
  <!-- Hero -->
  <section
    class="hero-gradient text-white py-16 md:py-24"
    style="--hero-image: url('/images/backgrounds/hero-students.webp');"
    data-testid="blogs-hero"
  >
    <div class="container-custom">
      <p class="text-secondary-300 font-medium mb-2">
        {t("nav.blogs", locale)}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold font-heading">
        {t("blogs.latest", locale)}
      </h1>
    </div>
  </section>

  <!-- Blogs Grid -->
  <Section class="section-photo transition-colors duration-200" data-testid="blogs-list">
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        {
          posts.length > 0 ? (
            <div class="grid md:grid-cols-2 gap-6">
              {posts.map((blog: any) => <BlogCard blog={blog} locale={locale} />)}
            </div>
          ) : (
            <div class="rounded-2xl border border-dashed border-gray-300 dark:border-slate-700 bg-white/80 dark:bg-slate-800 p-10 text-center">
              <Icon name="tabler:news-off" class="w-14 h-14 mx-auto text-gray-400 dark:text-gray-500 mb-4" />
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">No published posts yet</h2>
              <p class="mt-2 text-gray-600 dark:text-gray-300">Check back later for the latest updates from this tenant.</p>
            </div>
          )
        }
      </div>

      <BlogSidebar locale={locale} />
    </div>
  </Section>
</Layout>

---
import Layout from "../../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Section from "../../../components/public/Section.astro";
import BlogCard from "../../../components/public/BlogCard.astro";
import WidgetArea from "../../../components/common/WidgetArea.astro";
import {
  t,
  getLocalizedPath,
  type Locale,
} from "../../../utils/i18n";
import { getPosts } from "../../../lib/api";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const { locale } = Astro.params as { locale: Locale };
const posts = await getPosts(100, locale);
// posts are already sorted by default from API
---

<Layout title={t("blogs.title", locale)} pageType="blog_archive">
  <!-- Hero -->
  <section
    class="hero-gradient text-white py-16 md:py-24"
    style="--hero-image: url('/images/backgrounds/hero-students.webp');"
    data-testid="blogs-hero"
  >
    <div class="container-custom">
      <p class="text-secondary-300 font-medium mb-2">
        {t("nav.blogs", locale)}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold font-heading">
        {t("blogs.latest", locale)}
      </h1>
    </div>
  </section>

  <!-- Blogs Grid -->
  <Section class="section-photo transition-colors duration-200" data-testid="blogs-list">
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="grid md:grid-cols-2 gap-6">
          {posts.map((blog: any) => <BlogCard blog={blog} locale={locale} />)}
        </div>
      </div>

      <div class="space-y-6">
        <WidgetArea area="sidebar" />
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-6 transition-colors duration-200">
          <a href={getLocalizedPath("/blogs/agenda", locale)} class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">
            <span class="text-gray-700 dark:text-gray-300">{t("blogs.agenda", locale)}</span>
            <Icon name="tabler:chevron-right" class="w-5 h-5 text-gray-400" />
          </a>
          <a href={getLocalizedPath("/blogs/galeri", locale)} class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">
            <span class="text-gray-700 dark:text-gray-300">{t("blogs.gallery", locale)}</span>
            <Icon name="tabler:chevron-right" class="w-5 h-5 text-gray-400" />
          </a>
        </div>
      </div>
    </div>
  </Section>
</Layout>

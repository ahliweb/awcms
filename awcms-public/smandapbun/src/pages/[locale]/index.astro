---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Section from "../../components/public/Section.astro";
import StatGrid from "../../components/public/StatGrid.astro";
import SplitSection from "../../components/public/SplitSection.astro";
import BlogCard from "../../components/public/BlogCard.astro";
import CtaBanner from "../../components/public/CtaBanner.astro";
import {
  t,
  getLocalizedValue,
  getLocalizedPath,
  type Locale,
} from "../../utils/i18n";
import { getAdminPageBySlug, getSiteData, getPosts, getProfilePageData } from "../../lib/api";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const { locale } = Astro.params as { locale: Locale };

const site = await getSiteData();
const posts = await getPosts(3, locale);
const profileData = await getProfilePageData();
const { principalMessage: principalMessageFallback } = profileData;
const principalMessagePage = await getAdminPageBySlug("sambutan-kepala-sekolah", locale);
const principalMessage = principalMessagePage
  ? {
      title: { id: principalMessagePage.title, en: principalMessagePage.title },
      content: {
        id:
          principalMessagePage.content ||
          getLocalizedValue(principalMessageFallback.content, "id"),
        en:
          principalMessagePage.content ||
          getLocalizedValue(principalMessageFallback.content, "en"),
      },
      author: principalMessageFallback.author,
      position: principalMessageFallback.position,
      image: principalMessagePage.featured_image || principalMessageFallback.image,
    }
  : principalMessageFallback;
const featuredBlogs = posts.filter((a) => a.featured).slice(0, 3);
const siteName = getLocalizedValue<string>(site.site.name, locale) || "SMAN 2 Pangkalan Bun";
const siteTagline = getLocalizedValue<string>(site.site.tagline, locale) || t("home.tagline", locale);
const siteDescription = getLocalizedValue<string>(site.site.description, locale) || t("home.about_desc", locale);

// Import assets
import { HeroSlider } from "../../components/HeroSlider";
import { sanitizeHTML } from "../../utils/sanitize";
const images = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/foto-smandapbun/foto-campur-smanda/*.webp",
  { eager: true },
);
const heroImages = Object.values(images).map((img) => img.default);
const statItems = [
  { value: `${site.stats.students.toLocaleString()}+`, label: t("home.stats_students", locale) },
  { value: `${site.stats.teachers}+`, label: t("home.stats_teachers", locale) },
  { value: `${site.stats.alumni?.toLocaleString() || 0}+`, label: t("home.stats_alumni", locale) },
  { value: `${site.stats.achievements}+`, label: t("home.stats_achievements", locale) },
];
---

<Layout title={siteName} description={siteDescription} pageType="home">
  <!-- Hero Section -->
  <section
    class="text-white relative overflow-hidden"
    data-testid="hero-section"
  >
    <HeroSlider client:load images={heroImages} />
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-20 right-10 w-96 h-96 bg-secondary-400 rounded-full blur-3xl"
      >
      </div>
    </div>
    <div class="container-custom py-20 md:py-32 relative z-30 drop-shadow-md">
      <div class="max-w-3xl">
        <p class="text-secondary-300 font-medium mb-4 animate-fade-in">
          {t("home.welcome", locale)}
        </p>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 font-heading animate-fade-in"
          style="animation-delay: 0.1s;"
        >
          {siteName}
        </h1>
        <p
          class="text-xl md:text-2xl text-blue-100 mb-8 animate-fade-in"
          style="animation-delay: 0.2s;"
        >
          {siteTagline}
        </p>
        <div
          class="flex flex-wrap gap-4 animate-fade-in"
          style="animation-delay: 0.3s;"
        >
          <a
            href={getLocalizedPath("/profil", locale)}
            class="btn-secondary"
            data-testid="hero-profile-btn"
          >
            <Icon name="tabler:building" class="w-5 h-5 mr-2" />
            {t("profile.title", locale)}
          </a>
          <a
            href={getLocalizedPath("/kontak", locale)}
            class="btn-outline border-white text-white hover:bg-white hover:text-primary-600"
            data-testid="hero-contact-btn"
          >
            <Icon name="tabler:phone" class="w-5 h-5 mr-2" />
            {t("common.contact_us", locale)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-white dark:bg-slate-800 relative -mt-8 z-20 transition-colors duration-200">
    <div class="container-custom">
      <StatGrid items={statItems} />
    </div>
  </section>

  <Section class="section-photo transition-colors duration-200" muted>
    <SplitSection
      title={siteName}
      description={siteDescription}
      image={{ src: "/images/backgrounds/hero-profile.webp", alt: t("home.school_alt", locale) }}
      primaryHref={getLocalizedPath("/profil/visi-misi", locale)}
      primaryLabel={t("common.learn_more", locale)}
      highlights={[
        { value: site.accreditation, label: "Accreditation" },
        { value: site.established, label: "Established" },
      ]}
    >
      <Fragment slot="overlay">
        <div class="absolute -bottom-6 -left-6 bg-secondary-500 text-white p-6 rounded-xl shadow-lg">
          <div class="text-3xl font-bold">{new Date().getFullYear() - parseInt(site.established)}+</div>
          <div class="text-sm">{t("home.years_of_experience", locale)}</div>
        </div>
      </Fragment>
    </SplitSection>
  </Section>

  <!-- Principal Welcome Section -->
  <section
    class="py-16 md:py-24 bg-white dark:bg-slate-800 transition-colors duration-200"
    data-testid="principal-section"
  >
    <div class="container-custom">
      <div
        class="bg-primary-50 dark:bg-slate-900 rounded-3xl p-8 md:p-12 shadow-sm border border-primary-100 dark:border-slate-700"
      >
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div class="order-2 md:order-1">
            <h2 class="section-title text-gray-900 dark:text-white mb-6">
              {getLocalizedValue(principalMessage.title, locale)}
            </h2>
            <div
              class="prose dark:prose-invert max-w-none mb-8 line-clamp-4 text-gray-600 dark:text-gray-300"
            >
              <div
                set:html={sanitizeHTML(getLocalizedValue(principalMessage.content, locale))}
              />
            </div>
            <div class="flex items-center gap-4 mb-6">
              <div class="text-left">
                <h3 class="font-bold text-gray-900 dark:text-white text-lg">
                  {principalMessage.author}
                </h3>
                <p class="text-primary-600 dark:text-blue-400 text-sm">
                  {principalMessage.position}
                </p>
              </div>
            </div>
            <a
              href={getLocalizedPath("/profil/sambutan-kepala-sekolah", locale)}
              class="btn-primary"
            >
              Read More
              <Icon name="tabler:arrow-right" class="w-5 h-5 ml-2" />
            </a>
          </div>
          <div
            class="order-1 md:order-2 flex justify-center md:justify-end relative"
          >
            <div class="relative w-64 h-64 md:w-80 md:h-80">
              <div
                class="absolute inset-0 bg-primary-200 dark:bg-slate-700 rounded-full blur-2xl opacity-50 transform translate-y-4"
              >
              </div>
              {
                principalMessage.image ? (
                  <div class="relative w-full h-full rounded-2xl overflow-hidden shadow-xl border-4 border-white dark:border-slate-800 rotate-3 transition-transform hover:rotate-0 duration-300">
                    <img
                      src={principalMessage.image}
                      alt={principalMessage.author}
                      class="w-full h-full object-cover"
                    />
                  </div>
                ) : (
                  <div class="relative w-full h-full bg-gray-200 dark:bg-slate-700 rounded-2xl flex items-center justify-center text-primary-600 dark:text-gray-400 shadow-xl border-4 border-white dark:border-slate-800 rotate-3">
                    <Icon name="tabler:user" class="w-24 h-24" />
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Blogs Section -->
  <Section eyebrow={t("blogs.title", locale)} title={t("home.latest_blogs", locale)} muted>
    <div class="flex justify-end mb-8">
      <a
        href={getLocalizedPath("/blogs", locale)}
        class="hidden md:flex items-center text-primary-600 dark:text-primary-400 font-medium hover:text-primary-700 dark:hover:text-primary-300"
        data-testid="blogs-view-all"
      >
        {t("common.view_all", locale)}
        <Icon name="tabler:arrow-right" class="w-5 h-5 ml-1" />
      </a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredBlogs.map((blog: any) => <BlogCard blog={blog} locale={locale} />)}
    </div>
    <div class="mt-8 text-center md:hidden">
      <a href={getLocalizedPath("/blogs", locale)} class="btn-primary">{t("common.view_all", locale)}</a>
    </div>
  </Section>

  <CtaBanner
    title={t("home.join_us", locale)}
    description={t("home.join_us_desc", locale)}
    backgroundImage="/images/backgrounds/hero-activity.webp"
    actions={[
      { href: "#", label: t("home.ppdb", locale) },
      { href: getLocalizedPath("/kontak", locale), label: t("common.contact_us", locale), variant: "outline" },
    ]}
  />
</Layout>

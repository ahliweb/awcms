---
import type { GetStaticPaths } from "astro";
import AdminManagedPage from "../../components/AdminManagedPage.astro";
import { getAdminPageSlugs } from "../../lib/api";
import type { Locale } from "../../utils/i18n";

export const prerender = true;

export const getStaticPaths = (async () => {
  const slugs = await getAdminPageSlugs("en");
  return slugs.map((slug) => ({ params: { locale: "en", slug } }));
}) satisfies GetStaticPaths;

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
---

<AdminManagedPage slug={slug || ""} locale={locale} />

---
import AdminManagedPage from "../../../components/AdminManagedPage.astro";
import { getLocalizedPath, type Locale } from "../../../utils/i18n";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { locale: "en" } }];
}

const { locale } = Astro.params as { locale: Locale };
---

<AdminManagedPage slug="prestasi" locale={locale} backHref={getLocalizedPath("/", locale)} />

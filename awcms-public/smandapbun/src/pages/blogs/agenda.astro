---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/public/PageHero.astro";
import AgendaArchiveContent from "../../components/public/AgendaArchiveContent.astro";
import { getLocale, t, getLocalizedValue, getLocalizedPath, type Locale } from "../../utils/i18n";
import { getAdminPageBySlug, getAgendaData } from "../../lib/api";
import kalenderPdf from "../../assets/smandapbun-materi-web/smandapbun-kaldik.pdf";
import { sanitizeHTML } from "../../utils/sanitize";

const locale = getLocale(Astro.url) as Locale;
const agendaData = await getAgendaData();
const agendaPage = await getAdminPageBySlug("agenda", locale);
const { agenda } = agendaData;
const pageTitle = agendaPage?.title || getLocalizedValue(agenda.title, locale) || t("blogs.agenda", locale);
const pageDescription = agendaPage?.excerpt || undefined;
---

<Layout title={pageTitle} description={pageDescription} pageType="agenda_archive">
  <PageHero title={pageTitle} description={pageDescription} image="/images/backgrounds/hero-ceremony.webp" breadcrumbs={[{ href: getLocalizedPath("/", locale), label: "Beranda" }, { href: getLocalizedPath("/blogs", locale), label: t("blogs.title", locale) }, { label: t("blogs.agenda", locale) }]} testId="agenda-hero" />
  <AgendaArchiveContent locale={locale} pageHtml={agendaPage?.content ? sanitizeHTML(agendaPage.content) : null} events={agenda.events} kalenderPdf={kalenderPdf} />
</Layout>

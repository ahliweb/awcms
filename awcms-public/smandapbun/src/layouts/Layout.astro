---
import BaseLayout from "./BaseLayout.astro";
import {
  getLocale,
  getLocalizedPath,
  getLocalizedValue,
  type Locale,
} from "../utils/i18n";
import { getAnalyticsConsent, getSiteData } from "../lib/api";
import {
  createPublicPageContext,
  type PublicContentRef,
  type PublicMetadata,
  type PublicPageContext,
} from "../lib/publicPageContext";
import { getPublicTenantId } from "../lib/publicTenant";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  metadata?: PublicMetadata;
  pageType?: string;
  contentRef?: PublicContentRef;
  pageContext?: PublicPageContext;
}

const locale = getLocale(Astro.url) as Locale;

const siteData = await getSiteData();
const locals = (Astro.locals ?? {}) as {
  tenant_id?: string;
  analytics_consent?: Record<string, unknown>;
};
const analyticsConsent =
  locals.analytics_consent ??
  (await getAnalyticsConsent(locals.tenant_id ?? null));

const {
  title,
  description,
  image,
  canonical,
  metadata,
  pageType = "website",
  contentRef,
  pageContext,
} = Astro.props;

const localizedSiteName =
  getLocalizedValue<string>(siteData.site.name, locale) || "SMAN 2 Pangkalan Bun";

const resolvedTitle = title || metadata?.title || localizedSiteName;
const resolvedDescription =
  description ||
  metadata?.description ||
  getLocalizedValue(siteData.site.description, locale) ||
  "SMAN 2 Pangkalan Bun";
const resolvedImage =
  image || metadata?.openGraph?.images?.[0]?.url || "/images/og-image.jpg";
const resolvedCanonical =
  canonical || metadata?.canonical || getLocalizedPath(Astro.url.pathname, locale);

const siteTitle =
  resolvedTitle === localizedSiteName
    ? resolvedTitle
    : `${resolvedTitle} | ${localizedSiteName}`;

const normalizedMetadata: PublicMetadata = {
  ...(metadata || {}),
  title: siteTitle,
  description: resolvedDescription,
  canonical: resolvedCanonical,
  openGraph: {
    ...(metadata?.openGraph || {}),
    images: resolvedImage ? [{ url: resolvedImage }] : metadata?.openGraph?.images,
  },
};

const tenantId = locals.tenant_id || getPublicTenantId();
const normalizedPageContext =
  pageContext ||
  createPublicPageContext({
    metadata: normalizedMetadata,
    pageType,
    locale,
    tenantId,
    content: contentRef,
  });
---

<BaseLayout
  locale={locale}
  metadata={normalizedMetadata}
  pageContext={normalizedPageContext}
  analyticsConsent={analyticsConsent}
  favicon={siteData.site.favicon}
>
  <slot />
</BaseLayout>

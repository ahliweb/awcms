---
import { createClientFromEnv } from "../../lib/supabase";
import { getPublicTenantId } from "../../lib/publicTenant";
import {
  getActivePlugins,
  getPluginFragments,
  getPluginMetadataTags,
  renderPluginFragments,
  renderPluginMetadataTags,
} from "../../lib/plugins";
import type { PublicMetadata, PublicPageContext } from "../../lib/publicPageContext";

interface Props {
  metadata?: PublicMetadata;
  pageContext?: PublicPageContext;
}

const { metadata = {}, pageContext } = Astro.props;
const supabase = createClientFromEnv(import.meta.env);
const tenantId = pageContext?.tenantId || getPublicTenantId();

let pluginHeadHtml = "";

if (supabase) {
  try {
    const plugins = await getActivePlugins(supabase, tenantId);
    pluginHeadHtml = [
      renderPluginMetadataTags(getPluginMetadataTags(plugins, pageContext)),
      renderPluginFragments(getPluginFragments(plugins, "head", pageContext)),
    ]
      .filter(Boolean)
      .join("\n");
  } catch (error) {
    console.error("[PublicHead] Failed to resolve plugin head content:", error);
  }
}
---

{metadata.canonical && <link rel="canonical" href={metadata.canonical} />}
<Fragment set:html={pluginHeadHtml} />

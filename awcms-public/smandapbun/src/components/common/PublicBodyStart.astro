---
import { createClientFromEnv } from "../../lib/supabase";
import { getPublicTenantId } from "../../lib/publicTenant";
import { getActivePlugins, getPluginFragments, renderPluginFragments } from "../../lib/plugins";
import type { PublicPageContext } from "../../lib/publicPageContext";

interface Props {
  pageContext?: PublicPageContext;
}

const { pageContext } = Astro.props;
const supabase = createClientFromEnv(import.meta.env);
const tenantId = pageContext?.tenantId || getPublicTenantId();

let html = "";

if (supabase) {
  try {
    const plugins = await getActivePlugins(supabase, tenantId);
    html = renderPluginFragments(getPluginFragments(plugins, "body_start", pageContext));
  } catch (error) {
    console.error("[PublicBodyStart] Failed to resolve plugin body-start content:", error);
  }
}
---

<Fragment set:html={html} />

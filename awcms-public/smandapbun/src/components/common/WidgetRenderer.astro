---
import type { WidgetData } from "../../lib/widgets";
import { createClientFromEnv } from "../../lib/supabase";
import { getPublicTenantId } from "../../lib/publicTenant";
import { getLocale } from "../../utils/i18n";

export interface Props {
  widget: WidgetData;
  class?: string;
}

const { widget, class: className = "" } = Astro.props;
const { type, name, config, content, show_title, custom_classes } = widget;
const rawEmdashPayload = widget.raw_emdash_payload || null;
const emdashComponentId =
  rawEmdashPayload && typeof rawEmdashPayload === "object"
    ? rawEmdashPayload.componentId
    : null;

type PortableTextChild = { text?: string };
type PortableTextBlock = { children?: PortableTextChild[] };

const getPortableTextText = (value: PortableTextBlock[] | unknown) => {
  if (!Array.isArray(value)) return "";
  return value
    .map((block) =>
      Array.isArray(block?.children)
        ? block.children.map((child: PortableTextChild) => child?.text || "").join("")
        : "",
    )
    .filter(Boolean)
    .join("\n\n");
};

const effectiveType =
  emdashComponentId === "core:archives"
    ? "archives"
    : emdashComponentId === "core:recent-posts"
      ? "recent_posts"
      : emdashComponentId === "core:categories"
        ? "categories"
        : emdashComponentId === "core:tags"
          ? "tags"
          : emdashComponentId === "core:search"
            ? "search"
            : type;

const contentText =
  type === "content" ? getPortableTextText(content || rawEmdashPayload?.content) : "";

const supabase = createClientFromEnv(import.meta.env);
const tenantId = getPublicTenantId();
const locale = getLocale(Astro.url);

type BlogWidgetPost = {
  id: string;
  title: string;
  slug: string;
  published_at: string | null;
  created_at: string;
};

type NamedTerm = {
  id: string;
  name: string;
  slug: string;
};

const recentPosts: BlogWidgetPost[] = [];
const categories: NamedTerm[] = [];
const tags: NamedTerm[] = [];
const archives: Array<{ label: string; href: string; count: number }> = [];

if (supabase && effectiveType === "recent_posts") {
  let query = supabase
    .from("blogs")
    .select("id, title, slug, published_at, created_at")
    .eq("status", "published")
    .is("deleted_at", null)
    .order("published_at", { ascending: false })
    .limit(5);

  query = tenantId ? query.eq("tenant_id", tenantId) : query.is("tenant_id", null);
  const { data } = await query;
  recentPosts.push(...((data || []) as BlogWidgetPost[]));
}

if (supabase && effectiveType === "categories") {
  let query = supabase
    .from("categories")
    .select("id, name, slug")
    .is("deleted_at", null)
    .order("name", { ascending: true })
    .limit(12);

  query = tenantId ? query.eq("tenant_id", tenantId) : query.is("tenant_id", null);
  const { data } = await query;
  categories.push(...((data || []) as NamedTerm[]));
}

if (supabase && effectiveType === "tags") {
  let query = supabase
    .from("tags")
    .select("id, name, slug")
    .is("deleted_at", null)
    .order("name", { ascending: true })
    .limit(20);

  query = tenantId ? query.eq("tenant_id", tenantId) : query.is("tenant_id", null);
  const { data } = await query;
  tags.push(...((data || []) as NamedTerm[]));
}

if (supabase && effectiveType === "archives") {
  let query = supabase
    .from("blogs")
    .select("published_at, created_at")
    .eq("status", "published")
    .is("deleted_at", null)
    .order("published_at", { ascending: false })
    .limit(50);

  query = tenantId ? query.eq("tenant_id", tenantId) : query.is("tenant_id", null);
  const { data } = await query;
  const grouped = new Map<string, { label: string; href: string; count: number }>();

  for (const row of (data || []) as Array<{ published_at: string | null; created_at: string }>) {
    const source = row.published_at || row.created_at;
    if (!source) continue;
    const date = new Date(source);
    if (Number.isNaN(date.getTime())) continue;

    const year = date.getUTCFullYear();
    const month = String(date.getUTCMonth() + 1).padStart(2, "0");
    const key = `${year}-${month}`;
    const label = date.toLocaleDateString(locale === "id" ? "id-ID" : "en-US", {
      year: "numeric",
      month: "long",
    });

    const existing = grouped.get(key);
    if (existing) {
      existing.count += 1;
    } else {
      grouped.set(key, {
        label,
        href: `/${locale}/blogs?archive=${key}`,
        count: 1,
      });
    }
  }

  archives.push(...grouped.values());
}

const linkItems =
  type === "links" && Array.isArray(config?.items)
    ? (config.items as Array<{ title: string; url: string; icon?: string }>)
    : [];

const socialLinks =
  type === "social" && Array.isArray(config?.links)
    ? (config.links as Array<{ platform: string; url: string }>)
    : [];

function getContainerClasses(widgetType: string): string {
  const baseClasses =
    "widget p-4 rounded-xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700";
  switch (widgetType) {
    case "featured":
      return `${baseClasses} bg-gradient-to-br from-primary/5 to-primary/10`;
    case "cta":
      return `${baseClasses} bg-primary text-white`;
    case "minimal":
      return "widget py-2";
    default:
      return baseClasses;
  }
}
---

<div class:list={[getContainerClasses(effectiveType), custom_classes, className]}>
  {
    show_title && name && (
      <h3 class="text-lg font-semibold mb-3 text-slate-800 dark:text-slate-200">{name}</h3>
    )
  }

  <div class="widget-content">
    {effectiveType === "text" && <div class="prose prose-sm dark:prose-invert max-w-none" set:html={content || ""} />}
    {effectiveType === "html" && <div set:html={content || ""} />}
    {effectiveType === "content" && contentText && <div class="space-y-3 text-sm leading-6 text-slate-600 dark:text-slate-300 whitespace-pre-line">{contentText}</div>}
    {
      effectiveType === "search" && (
        <form action={`/${locale}/blogs`} method="GET" class="space-y-3">
          <input type="search" name="q" placeholder="Search posts" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm dark:border-slate-700 dark:bg-slate-900" />
          <button type="submit" class="inline-flex rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700">Search</button>
        </form>
      )
    }
    {
      effectiveType === "image" && config?.src && (
        <figure>
          <img src={config.src as string} alt={(config.alt as string) || ""} class="w-full rounded-lg" loading="lazy" />
          {config.caption && <figcaption class="mt-2 text-sm text-slate-500 dark:text-slate-400 text-center">{config.caption}</figcaption>}
        </figure>
      )
    }
    {
      effectiveType === "links" && linkItems.length > 0 && (
        <ul class="space-y-2">
          {linkItems.map((item) => (
            <li>
              <a href={item.url} class="flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                {item.icon && <span class="w-4 h-4">{item.icon}</span>}
                <span>{item.title}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    {
      effectiveType === "recent_posts" && (
        <div class="space-y-3">
          {recentPosts.length > 0 ? recentPosts.map((post) => (
            <a href={`/${locale}/blogs/${post.slug}`} class="block rounded-xl border border-slate-200/70 px-3 py-3 transition hover:border-primary-400 hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800/70">
              <p class="text-sm font-medium text-slate-900 dark:text-slate-100">{post.title}</p>
              <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{new Date(post.published_at || post.created_at).toLocaleDateString(locale === "id" ? "id-ID" : "en-US", { year: "numeric", month: "short", day: "numeric" })}</p>
            </a>
          )) : <p class="text-sm text-slate-500 dark:text-slate-400 italic">No recent posts found.</p>}
        </div>
      )
    }
    {
      effectiveType === "categories" && (
        <div class="flex flex-wrap gap-2">
          {categories.length > 0 ? categories.map((category) => (
            <a href={`/${locale}/blogs?category=${category.slug}`} class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700 transition hover:bg-primary-100 hover:text-primary-700 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600">{category.name}</a>
          )) : <p class="text-sm text-slate-500 dark:text-slate-400 italic">No categories found.</p>}
        </div>
      )
    }
    {
      effectiveType === "tags" && (
        <div class="flex flex-wrap gap-2">
          {tags.length > 0 ? tags.map((tag) => (
            <a href={`/${locale}/blogs?tag=${tag.slug}`} class="rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-700 transition hover:border-primary-300 hover:text-primary-700 dark:border-slate-700 dark:text-slate-200 dark:hover:border-primary-400 dark:hover:text-primary-300">#{tag.name}</a>
          )) : <p class="text-sm text-slate-500 dark:text-slate-400 italic">No tags found.</p>}
        </div>
      )
    }
    {
      effectiveType === "archives" && (
        <div class="space-y-2">
          {archives.length > 0 ? archives.map((entry) => (
            <a href={entry.href} class="flex items-center justify-between rounded-lg px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-50 dark:text-slate-200 dark:hover:bg-slate-700/60">
              <span>{entry.label}</span>
              <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs dark:bg-slate-700">{entry.count}</span>
            </a>
          )) : <p class="text-sm text-slate-500 dark:text-slate-400 italic">No archives found.</p>}
        </div>
      )
    }
    {
      effectiveType === "social" && socialLinks.length > 0 && (
        <div class="flex flex-wrap gap-3">
          {socialLinks.map((item) => (
            <a href={item.url} class="rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-700 transition hover:border-primary-300 hover:text-primary-700 dark:border-slate-700 dark:text-slate-200 dark:hover:border-primary-400 dark:hover:text-primary-300">{item.platform}</a>
          ))}
        </div>
      )
    }
  </div>
</div>

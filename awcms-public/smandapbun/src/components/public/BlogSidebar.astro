---
import WidgetArea from "../common/WidgetArea.astro";
import PublicMenuList from "../common/PublicMenuList.astro";
import { getLocalizedPath, getLocalizedValue, type Locale } from "../../utils/i18n";
import { getMenuTree, type Post } from "../../lib/api";

interface Props {
  locale: Locale;
  relatedBlogs?: Post[];
}

const { locale, relatedBlogs = [] } = Astro.props;
const sidebarMenu = await getMenuTree("public_sidebar", locale);
const fallbackExploreLinks = [
  { id: "latest", label: "Latest Posts", href: "/blogs" },
  { id: "agenda", label: "Agenda", href: "/blogs/agenda" },
  { id: "gallery", label: "Gallery", href: "/blogs/galeri" },
];
const exploreItems = sidebarMenu.length > 0 ? sidebarMenu : fallbackExploreLinks;
---

<div class="space-y-6">
  <WidgetArea area="sidebar" />

  {
    relatedBlogs.length > 0 && (
      <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-6 transition-colors duration-200" data-testid="related-blogs">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white mb-4">Related Posts</h3>
        <div class="space-y-4">
          {relatedBlogs.map((related) => (
            <a href={getLocalizedPath(`/blogs/${related.slug}`, locale)} class="block group">
              <div class="flex gap-3">
                <div class="w-20 h-14 bg-gray-200 dark:bg-slate-700 rounded-lg overflow-hidden flex-shrink-0">
                  <img
                    src={related.image || `https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=100&h=70&fit=crop`}
                    alt={getLocalizedValue(related.title, locale)}
                    class="w-full h-full object-cover"
                  />
                </div>
                <div>
                  <h4 class="font-medium text-gray-900 dark:text-white text-sm line-clamp-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                    {getLocalizedValue(related.title, locale)}
                  </h4>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    {new Date(related.published_at).toLocaleDateString(locale === "id" ? "id-ID" : "en-US")}
                  </p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )
  }

  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-6 transition-colors duration-200">
    <h3 class="font-bold text-lg text-gray-900 dark:text-white mb-4">Explore</h3>
    <PublicMenuList
      items={exploreItems}
      locale={locale}
      class="space-y-2"
      linkClass="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors text-gray-700 dark:text-gray-300"
      nestedClass="ml-3 mt-2 space-y-2 border-l border-slate-200 dark:border-slate-700 pl-3"
    />
  </div>
</div>

---
interface Props {
  html?: string | null;
  class?: string;
}

const { html, class: className = "" } = Astro.props;
---

{
  html && (
    <div class:list={["rounded-2xl bg-white dark:bg-slate-800 shadow-sm p-8 prose dark:prose-invert max-w-none transition-colors duration-200", className]}>
      <Fragment set:html={html} />
    </div>
  )
}

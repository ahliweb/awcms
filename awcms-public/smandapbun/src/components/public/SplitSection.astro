---
interface HighlightItem {
  value: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  image: { src: string; alt: string };
  primaryHref?: string;
  primaryLabel?: string;
  highlights?: HighlightItem[];
  reverse?: boolean;
}

const {
  title,
  description,
  image,
  primaryHref,
  primaryLabel,
  highlights = [],
  reverse = false,
} = Astro.props;
---

<div class:list={["grid lg:grid-cols-2 gap-12 items-center", reverse && "lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1"]}>
  <div>
    <h3 class="section-title text-gray-900 dark:text-white">{title}</h3>
    {description && <p class="text-gray-600 dark:text-gray-300 mb-6">{description}</p>}
    {
      highlights.length > 0 && (
        <div class="grid grid-cols-2 gap-4 mb-6">
          {highlights.map((item) => (
            <div class="bg-white dark:bg-slate-800 p-4 rounded-xl transition-colors">
              <div class="text-2xl font-bold text-primary-600 dark:text-primary-400">{item.value}</div>
              <div class="text-sm text-gray-500 dark:text-gray-400">{item.label}</div>
            </div>
          ))}
        </div>
      )
    }
    {primaryHref && primaryLabel && (
      <a href={primaryHref} class="btn-primary">
        {primaryLabel}
        <span class="ml-2">&rarr;</span>
      </a>
    )}
  </div>
  <div class="relative">
    <div class="aspect-video bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-900 dark:to-primary-800 rounded-2xl overflow-hidden">
      <img src={image.src} alt={image.alt} class="w-full h-full object-cover" />
    </div>
    <slot name="overlay" />
  </div>
</div>

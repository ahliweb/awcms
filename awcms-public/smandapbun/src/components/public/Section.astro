---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  align?: "left" | "center";
  muted?: boolean;
  class?: string;
}

const {
  id,
  eyebrow,
  title,
  description,
  align = "left",
  muted = false,
  class: className = "",
} = Astro.props;

const alignClass = align === "center" ? "text-center items-center" : "text-left items-start";
---

<section id={id} class:list={["py-16 md:py-24", muted && "bg-gray-50 dark:bg-slate-800/60", className]}>
  <div class="container-custom">
    {
      (eyebrow || title || description) && (
        <header class:list={["mb-10 flex flex-col gap-3", alignClass]}>
          {eyebrow && <p class="font-medium text-primary-600 dark:text-primary-400">{eyebrow}</p>}
          {title && <h2 class="section-title mb-0 text-gray-900 dark:text-white">{title}</h2>}
          {description && <p class="max-w-3xl text-gray-600 dark:text-gray-300">{description}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>

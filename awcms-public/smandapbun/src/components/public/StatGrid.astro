---
interface StatItem {
  value: string;
  label: string;
}

interface Props {
  items: StatItem[];
}

const { items = [] } = Astro.props;
---

<div class="bg-white dark:bg-slate-700 rounded-2xl shadow-2xl p-6 md:p-8 grid grid-cols-2 md:grid-cols-4 gap-6 transition-colors">
  {items.map((item) => (
    <div class="text-center">
      <div class="text-3xl md:text-4xl font-bold text-primary-600 dark:text-primary-400 mb-1">{item.value}</div>
      <div class="text-gray-500 dark:text-gray-400 text-sm">{item.label}</div>
    </div>
  ))}
</div>

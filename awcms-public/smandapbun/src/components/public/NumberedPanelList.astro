---
interface Item {
  value: string;
}

interface Props {
  title: string;
  items: Item[];
  accent?: "blue" | "green";
}

const { title, items = [], accent = "blue" } = Astro.props;

const accentClasses =
  accent === "green"
    ? "bg-green-100 dark:bg-green-900/50 text-green-600 dark:text-green-400"
    : "bg-blue-100 dark:bg-blue-900/50 text-blue-600 dark:text-blue-400";
---

<section>
  <h2 class="text-2xl font-bold font-heading mb-4 text-primary-600 dark:text-primary-400">{title}</h2>
  <ul class="space-y-4">
    {items.map((item, index) => (
      <li class="flex gap-4 p-4 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-gray-100 dark:border-slate-700">
        <span class:list={["flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full font-bold", accentClasses]}>
          {index + 1}
        </span>
        <p class="text-gray-700 dark:text-gray-300 pt-1">{item.value}</p>
      </li>
    ))}
  </ul>
</section>

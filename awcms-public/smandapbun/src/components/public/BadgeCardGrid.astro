---
interface Item {
  title: string;
  badge?: string;
  secondaryBadge?: string;
  description?: string;
}

interface Props {
  title?: string;
  items: Item[];
  columns?: 2 | 3;
}

const { title, items = [], columns = 2 } = Astro.props;
const columnClass = columns === 3 ? "md:grid-cols-2 lg:grid-cols-3" : "md:grid-cols-2";
---

<section class="mt-8">
  {title && <h2 class="text-2xl font-bold font-heading mb-6 text-primary-600 dark:text-primary-400">{title}</h2>}
  <div class:list={["grid gap-4", columnClass]}>
    {items.map((item) => (
      <div class="bg-white dark:bg-slate-800 p-6 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col h-full">
        <h3 class="text-xl font-bold font-heading mb-2 text-primary-600 dark:text-primary-400">{item.title}</h3>
        {
          (item.badge || item.secondaryBadge) && (
            <div class="flex items-center gap-4 mb-4 text-sm flex-wrap">
              {item.badge && <span class="bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 px-3 py-1 rounded-full font-medium">{item.badge}</span>}
              {item.secondaryBadge && <span class="bg-green-50 dark:bg-green-900/40 text-green-700 dark:text-green-300 px-3 py-1 rounded-full font-medium">{item.secondaryBadge}</span>}
            </div>
          )
        }
        {item.description && <p class="text-gray-600 dark:text-gray-400 mt-auto">{item.description}</p>}
      </div>
    ))}
  </div>
</section>

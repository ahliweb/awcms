---
interface Action {
  href: string;
  label: string;
  variant?: "primary" | "outline";
}

interface Props {
  title: string;
  description?: string;
  actions?: Action[];
  backgroundImage?: string;
}

const { title, description, actions = [], backgroundImage } = Astro.props;
---

<section
  class="py-16 md:py-24 hero-gradient text-white relative overflow-hidden"
  style={backgroundImage ? `--hero-image: url('${backgroundImage}');` : undefined}
>
  <div class="absolute inset-0 bg-black/20"></div>
  <div class="container-custom relative z-10 text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
    {description && <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">{description}</p>}
    {
      actions.length > 0 && (
        <div class="flex flex-wrap justify-center gap-4">
          {actions.map((action) => (
            <a
              href={action.href}
              class:list={[
                action.variant === "outline"
                  ? "btn-outline border-white text-white hover:bg-white hover:text-primary-600"
                  : "btn-secondary",
              ]}
            >
              {action.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

---
interface Item {
  label: string;
  value: string;
}

interface Props {
  items: Item[];
}

const { items = [] } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
  {items.map((item) => (
    <div class="bg-blue-50 dark:bg-slate-800 p-6 rounded-xl border border-blue-100 dark:border-slate-700 text-center flex flex-col items-center justify-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mb-1">{item.label}</p>
      <p class="text-xl font-bold text-gray-900 dark:text-white">{item.value}</p>
    </div>
  ))}
</div>

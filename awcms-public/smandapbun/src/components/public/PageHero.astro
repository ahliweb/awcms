---
interface Crumb {
  href?: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  image: string;
  eyebrow?: string;
  breadcrumbs?: Crumb[];
  testId?: string;
}

const {
  title,
  description,
  image,
  eyebrow,
  breadcrumbs = [],
  testId,
} = Astro.props;
---

<section class="hero-gradient text-white py-16 md:py-20" style={`--hero-image: url('${image}');`} data-testid={testId}>
  <div class="container-custom">
    {
      breadcrumbs.length > 0 && (
        <nav class="text-sm text-blue-200 mb-4">
          {breadcrumbs.map((crumb, index) => (
            <Fragment>
              {crumb.href ? <a href={crumb.href} class="hover:text-white">{crumb.label}</a> : <span class="text-white">{crumb.label}</span>}
              {index < breadcrumbs.length - 1 && <span class="mx-2">/</span>}
            </Fragment>
          ))}
        </nav>
      )
    }
    {eyebrow && <p class="text-secondary-300 font-medium mb-2">{eyebrow}</p>}
    <h1 class="text-3xl md:text-4xl font-bold font-heading">{title}</h1>
    {description && <p class="text-xl text-blue-100 mt-4 max-w-3xl">{description}</p>}
  </div>
</section>

APP_ENV=development
APP_URL=http://localhost:4321
LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=730

# Koneksi runtime aplikasi. Di produksi arahkan ke role `awcms_app` yang dibuat
# `sql/019_awcms_db_role_separation.sql` — role itu BUKAN superuser, BUKAN
# BYPASSRLS, dan BUKAN pemilik tabel, sehingga RLS benar-benar berlaku sebagai
# lapisan kedua isolasi tenant (lihat doc 18 §Model role database). Migration
# 019 membuatnya NOLOGIN tanpa password (password itu secret, tidak boleh ada
# di repo); operator mengaktifkannya sekali:
#   ALTER ROLE awcms_app LOGIN PASSWORD '<secret>';
# `bun run db:migrate` membaca DATABASE_URL yang SAMA, jadi jalankan migrasi
# dengan var ini ditimpa ke connection string owner/superuser — bukan awcms_app
# (awcms_app sengaja tidak bisa CREATE/ALTER/DROP apa pun). Grant awcms_app pada
# tabel global tanpa RLS sudah dipersempit oleh
# `sql/021_awcms_db_role_grants_narrow.sql` (Issue #160): read-only di
# awcms_permissions/awcms_schema_migrations, tanpa DELETE di
# awcms_tenants/awcms_setup_state — lihat doc 18 §Model role database.
DATABASE_URL=postgres://awcms:awcms_password@localhost:5432/awcms
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_PGBOUNCER=false
# Koneksi + pool TERPISAH untuk background job dan wizard setup, DAN opsi
# opt-in role least-privilege sungguhan. `sql/022_awcms_db_worker_setup_roles.sql`
# (Issue #163) membuat role `awcms_worker` (tujuh cron worker) dan `awcms_setup`
# (bootstrap `POST /api/v1/setup/initialize`), masing-masing hanya dengan GRANT
# per-jalur-tulis yang benar-benar dipakai kodenya — nol akses ke katalog global
# yang tidak disentuhnya (permissions/schema_migrations/setup_state/module
# registry). Keduanya NOLOGIN tanpa password; aktifkan sekali sama seperti
# awcms_app:
#   ALTER ROLE awcms_worker LOGIN PASSWORD '<secret>';
#   ALTER ROLE awcms_setup  LOGIN PASSWORD '<secret>';
# lalu arahkan var di bawah ke role itu. OPT-IN, BUKAN breaking: biarkan kosong
# -> keduanya fallback ke DATABASE_URL (koneksi `awcms_app`) — default yang
# didukung dan diuji, deployment yang mengelola satu connection string tetap
# jalan tanpa perubahan. Manfaat mengisinya: isolasi pool (job lambat tidak
# menghabiskan koneksi yang melayani HTTP, lihat DATABASE_POOL_MAX_*) PLUS
# isolasi role least-privilege nyata. Lihat doc 18 §Model role database.
WORKER_DATABASE_URL=
SETUP_DATABASE_URL=

AUTH_SESSION_TTL_MIN=120
AUTH_COOKIE_SECURE=true
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_LOGIN_RATE_LIMIT_WINDOW_SEC=60
# Percaya X-Forwarded-For sebagai sumber IP rate limit HANYA bila app berada di
# belakang proxy tepercaya yang MENIMPA (bukan menambah) header itu. Menyetel
# true pada app yang terekspos langsung membuat rate limit login bisa dilucuti:
# penyerang cukup merotasi header itu agar tiap request masuk bucket baru.
TRUSTED_PROXY_ENABLED=false
# Meng-key HMAC `ipHash` pada audit login. Kosong/placeholder -> kunci acak per
# proses: hash tetap non-reversible, tapi tidak sebanding antar restart/instance
# sehingga korelasi insiden lintas waktu hilang. Set nilai tetap di produksi.
AUTH_IP_HASH_SECRET=change-me

# MFA TOTP (Issue #184). AUTH_MFA_ENABLED gates the enrollment surface only —
# an existing factor is always honored at login/step-up regardless. When
# enabled, AUTH_MFA_SECRET_ENCRYPTION_KEY is REQUIRED and must be 32 bytes
# base64 (`openssl rand -base64 32`). There is NO default key: a database
# backup alone must never yield a usable TOTP secret.
AUTH_MFA_ENABLED=false
AUTH_MFA_SECRET_ENCRYPTION_KEY=
AUTH_MFA_TOTP_ISSUER=AWCMS
AUTH_MFA_TOTP_PERIOD_SEC=30
AUTH_MFA_TOTP_DIGITS=6
AUTH_MFA_TOTP_WINDOW_STEPS=1
AUTH_MFA_CHALLENGE_TTL_SEC=300
# Step-up freshness for high-risk actions — short and server-controlled.
AUTH_MFA_STEPUP_TTL_SEC=300
# Per-factor cumulative failed-verify lockout (independent of source IP and
# challenge rotation): lock a factor after N failed verifies for M minutes.
AUTH_MFA_MAX_VERIFY_ATTEMPTS=5
AUTH_MFA_LOCKOUT_MINUTES=15
AUTH_MFA_RATE_LIMIT_MAX=5
AUTH_MFA_RATE_LIMIT_WINDOW_SEC=300

AWCMS_SYNC_ENABLED=false
AWCMS_SYNC_HMAC_SECRET=change-me
AWCMS_SYNC_MAX_SKEW_SEC=300
# Terima signature sync legacy v1 (`<timestamp>.<body>`, TIDAK mengikat tenant/node).
# Default true selama transisi agar node lama tetap jalan. v1 masih rentan
# forgery lintas-tenant (GHSA-c972); setel `false` setelah SEMUA node kirim v2
# (`X-AWCMS-Signature-Version: 2`) untuk menutup celah sepenuhnya.
SYNC_HMAC_ALLOW_LEGACY=true

STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
R2_ENABLED=false

EMAIL_ENABLED=false
# EMAIL_PROVIDER: "mailketing" (real adapter) or "log" (safe local/dev, no network).
# EMAIL_PROVIDER=log
# EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=AWCMS
EMAIL_SEND_TIMEOUT_MS=10000
EMAIL_SEND_MAX_RETRIES=5
# Mailketing adapter (placeholders only — never commit real credentials):
# EMAIL_MAILKETING_ACCOUNT_ID=operator-label
# EMAIL_MAILKETING_API_TOKEN=replace-me
# EMAIL_MAILKETING_API_BASE_URL=https://api.mailketing.co.id

{
  "name": "awcms",
  "description": "AWCMS - Ahliweb Content Management System",
  "type": "module",
  "version": "4.3.1",
  "private": true,
  "scripts": {
    "secrets:rotate": "node scripts/rotate_db_password.js",
    "dev": "node scripts/check_secrets.js && vite",
    "dev:full": "node scripts/check_secrets.js && (cd ../awcms-edge && npm run dev:local &) && vite",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:platform-routes": "playwright test platform-tenant-switcher.spec.js platform-diagnostics.spec.js",
    "docs:check": "node ../scripts/check_markdown_local_links.mjs && npx markdown-link-check --config ../.mlc_config.json ../SYSTEM_MODEL.md ../README.md ../AGENTS.md README.md ../DOCS_INDEX.md ../CHANGELOG.md ../CONTRIBUTING.md ../SECURITY.md ../CODE_OF_CONDUCT.md ../docs/**/*.md ../awcms/README.md ../awcms-public/README.md ../awcms-public/primary/README.md ../awcms-public/smandapbun/README.md ../awcms-mobile/README.md ../awcms-mobile/primary/README.md ../awcms-esp32/README.md ../awcms-mcp/README.md ../awcms-ext/README.md ../awcms-edge/README.md ../packages/awcms-shared/README.md",
    "db:pull": "npx supabase db pull --schema public",
    "build": "vite build",
    "lint": "eslint ."
  },
  "dependencies": {
    "@puckeditor/core": "^0.21.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@tiptap/extension-image": "^3.13.0",
    "@tiptap/extension-link": "^3.13.0",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/extension-underline": "^3.13.0",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "flowbite": "^4.0.1",
    "framer-motion": "^12.36.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "otpauth": "^9.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.5.8",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.12",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "knip": "^5.84.1",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "minimatch": ">=10.2.1",
    "flatted": "^3.4.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}

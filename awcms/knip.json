{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.jsx",
    "src/pages/**/*.jsx",
    "src/scripts/**/*.js",
    "src/extensions/**/src/index.js",
    "src/plugins/**/index.js",
    "test-eslint.config.js",
    "debug-tenant.js",
    "empty.js"
  ],
  "project": [
    "src/**/*.{js,jsx}",
    "scripts/**/*.js",
    "*.js"
  ],
  "paths": {
    "@": ["./src"],
    "@/*": ["./src/*"],
    "@plugins": ["./src/plugins"],
    "@plugins/*": ["./src/plugins/*"]
  },
  "ignoreBinaries": [
    "markdown-link-check",
    "supabase"
  ],
  "ignoreDependencies": [
    "bcryptjs",
    "flowbite",
    "leaflet",
    "react-leaflet",
    "tailwindcss-animate",
    "@tailwindcss/typography",
    "tailwindcss"
  ],
  "ignoreFiles": [
    "public/leaflet/**",
    "src/templates/**",
    "src/components/public/Checkout.jsx",
    "src/components/public/ProductCatalog.jsx",
    "src/components/public/ShoppingCart.jsx",
    "src/contexts/CartContext.jsx"
  ],
  "ignoreIssues": {
    "src/extensions/**/src/index.js": ["exports", "duplicates"],
    "src/plugins/**/index.js": ["exports", "duplicates"],
    "src/templates/**": ["files", "exports", "duplicates"],
    "src/extensions/ahliweb-events/index.js": ["exports"],
    "src/lib/extensionManifest.js": ["exports"],
    "src/lib/templateExtensions.js": ["exports"],
    "src/plugins/helloworld/HelloWorld.jsx": ["exports"],
    "src/components/ui/LocalizedArrayEditor.jsx": ["exports", "duplicates"],
    "src/components/ui/LocalizedInput.jsx": ["exports", "duplicates"]
  },
  "ignoreExportsUsedInFile": true
}
